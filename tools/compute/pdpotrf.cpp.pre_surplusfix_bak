        void pthreads_dpotrf_expansion_semi_serial_imp4(TiledMatrix *tiledMatrix, stiles_context_t *stile) {
            (void)stile; // unused in Serial version

            const int rank = STILES_RANK;

            double** __restrict__ const chunked_tiles = tiledMatrix->chunkedDenseTiles;
            const sTiles::SemisparseTileMetaCore* __restrict__ const semisparse_meta = tiledMatrix->semisparseTileMetaCore;
            const sTiles::TileMetaCore* __restrict__ const tile_meta = tiledMatrix->tileMetaCore;

            const auto &tasks = sTiles::get_chol_tasks(tiledMatrix);
            const int start = 0;
            const int end = static_cast<int>(tasks.size());

            if (rank >= tiledMatrix->num_workspaces) {
                sTiles::Logger::error("[semisparse_imp3_serial] rank ", rank, " >= num_workspaces ", tiledMatrix->num_workspaces);
                return;
            }
            double* __restrict__ tmp_tile = tiledMatrix->workspaces[rank]->aligned_tile();
            const double mzone = -1.0;

            constexpr int FUSE_THRESHOLD = 16;

            // Loop-invariant fields hoisted out of the per-task body.
            const int ntiles_bounds = tiledMatrix->numActiveTiles;
            const int tile_size = tiledMatrix->tile_size;

            // Precomputed scatter info — required (param[7]==1, default in fast mode).
            // Case 4's dispatch reads scatter_index/scatter_packed unconditionally; the
            // runtime fallback was removed because build_chol_scatter_info is always
            // called by sTiles_preprocess_group_fastmode when param[7]==1.
            const int64_t* scatter_index = tiledMatrix->chol_scatter_index->data();
            const int32_t* scatter_packed = tiledMatrix->chol_scatter_packed->data();

            for (int idx = start; idx < end; ++idx) {
                const std::array<int,7> &t = tasks[idx];
                const int myroutine = t[0];
                const int index1 = t[4];
                const int index2 = t[5];
                const int index3 = t[6];

                // Prefetch: focus on first cache line of each tile (metadata is in regs by the
                // time we touch the body), plus indirection arrays (scatter_packed, aind) which
                // are unpredictable loads and benefit most from prefetch. _MM_HINT_T1 (==2) lands
                // in L2 to avoid L1 thrash with the current task's working set.
                if (idx + 1 < end) {
                    const std::array<int,7> &next_t = tasks[idx + 1];
                    const int next_routine = next_t[0];
                    const int next_idx1 = next_t[4];
                    const int next_idx2 = next_t[5];
                    if (next_idx1 >= 0 && next_idx1 < ntiles_bounds && chunked_tiles[next_idx1]) {
                        __builtin_prefetch(chunked_tiles[next_idx1], 0, 2);
                    }
                    if (next_idx2 >= 0 && next_idx2 < ntiles_bounds && chunked_tiles[next_idx2]) {
                        __builtin_prefetch(chunked_tiles[next_idx2], 1, 2);
                    }
                    if (next_routine == 4) {
                        const int next_idx3 = next_t[6];
                        if (next_idx3 >= 0 && next_idx3 < ntiles_bounds && chunked_tiles[next_idx3]) {
                            __builtin_prefetch(chunked_tiles[next_idx3], 1, 2);
                        }
                        const int64_t next_si = static_cast<int64_t>(idx + 1) * 2;
                        __builtin_prefetch(&scatter_index[next_si], 0, 3);
                        const int64_t next_data_off = scatter_index[next_si];
                        if (next_data_off >= 0) {
                            __builtin_prefetch(scatter_packed + next_data_off, 0, 3);
                        }
                    }
                    __builtin_prefetch(&semisparse_meta[next_idx1], 0, 3);
                    __builtin_prefetch(&semisparse_meta[next_idx2], 0, 3);
                    if (next_idx1 >= 0 && next_idx1 < ntiles_bounds) {
                        const int* aind_ptr = semisparse_meta[next_idx1].aind.data();
                        if (aind_ptr) __builtin_prefetch(aind_ptr, 0, 2);
                    }
                }

                switch (myroutine) {

                    case 4: { // DGEMM — C(k,m) -= A(n,k)^T * B(n,m)
                        double* __restrict__ chunk_a = chunked_tiles[index1];
                        double* __restrict__ chunk_b = chunked_tiles[index2];
                        double* __restrict__ chunk_out = chunked_tiles[index3];

                        const sTiles::SemisparseTileMetaCore& semi_a = semisparse_meta[index1];
                        const sTiles::SemisparseTileMetaCore& semi_b = semisparse_meta[index2];

                        const int cols_a = semi_a.sa;
                        const int cols_b = semi_b.sa;
                        const int rows_a = tile_meta[index1].height;
                        const int rows_out = tile_meta[index3].height;

                        // ── Dense path: precomputed path_flag dispatch ──
                        // Precondition: param[7]==1 (default in fast mode), which guarantees
                        // build_chol_scatter_info has populated scatter_index/scatter_packed.
                        const int si_base = idx * 2;
                        const int64_t data_off  = scatter_index[si_base];
                        const int path_flag = static_cast<int>(scatter_index[si_base + 1]);

                        if (path_flag == 0) {
                            // Direct GEMM: a_contig && b_contig && out_full
                            const int a_start = semi_a.fa;
                            const int b_start = semi_b.fa;
                            cblas_dgemm(CblasColMajor, CblasTrans, CblasNoTrans,
                                        cols_a, cols_b, rows_a, mzone,
                                        chunk_a, rows_a, chunk_b, rows_a,
                                        1.0, chunk_out + a_start + static_cast<std::size_t>(b_start) * rows_out, rows_out);

                        } else if (path_flag == 1) {
                            // Fused contiguous: vectorized dot + 2-i blocking (reuses col_b_j register)
                            const int a_start = semi_a.fa;
                            const int32_t* slots = scatter_packed + data_off;
                            const int cols_a_pair = cols_a & ~1;
                            for (int j = 0; j < cols_b; ++j) {
                                const int slot = slots[j];
                                if (slot < 0) continue;
                                double* __restrict__ out_col = chunk_out + static_cast<std::size_t>(slot) * rows_out + a_start;
                                const double* __restrict__ col_b_j = chunk_b + static_cast<std::size_t>(j) * rows_a;
                                int i = 0;
                                for (; i < cols_a_pair; i += 2) {
                                    const double* __restrict__ col_a_i0 = chunk_a + static_cast<std::size_t>(i)     * rows_a;
                                    const double* __restrict__ col_a_i1 = chunk_a + static_cast<std::size_t>(i + 1) * rows_a;
                                    double dot0 = 0.0, dot1 = 0.0;
                                    #pragma omp simd reduction(+:dot0,dot1)
                                    for (int r = 0; r < rows_a; ++r) {
                                        const double bv = col_b_j[r];
                                        dot0 += col_a_i0[r] * bv;
                                        dot1 += col_a_i1[r] * bv;
                                    }
                                    out_col[i]     -= dot0;
                                    out_col[i + 1] -= dot1;
                                }
                                if (i < cols_a) {
                                    const double* __restrict__ col_a_i = chunk_a + static_cast<std::size_t>(i) * rows_a;
                                    double dot = 0.0;
                                    #pragma omp simd reduction(+:dot)
                                    for (int r = 0; r < rows_a; ++r) dot += col_a_i[r] * col_b_j[r];
                                    out_col[i] -= dot;
                                }
                            }

                        } else if (path_flag == 2) {
                            // Fused scatter: vectorized dot + 2-i blocking
                            const int* __restrict__ aind_a = semi_a.aind.data();
                            const int32_t* slots = scatter_packed + data_off;
                            const int cols_a_pair = cols_a & ~1;
                            for (int j = 0; j < cols_b; ++j) {
                                const int slot = slots[j];
                                if (slot < 0) continue;
                                double* __restrict__ out_col = chunk_out + static_cast<std::size_t>(slot) * rows_out;
                                const double* __restrict__ col_b_j = chunk_b + static_cast<std::size_t>(j) * rows_a;
                                int i = 0;
                                for (; i < cols_a_pair; i += 2) {
                                    const double* __restrict__ col_a_i0 = chunk_a + static_cast<std::size_t>(i)     * rows_a;
                                    const double* __restrict__ col_a_i1 = chunk_a + static_cast<std::size_t>(i + 1) * rows_a;
                                    double dot0 = 0.0, dot1 = 0.0;
                                    #pragma omp simd reduction(+:dot0,dot1)
                                    for (int r = 0; r < rows_a; ++r) {
                                        const double bv = col_b_j[r];
                                        dot0 += col_a_i0[r] * bv;
                                        dot1 += col_a_i1[r] * bv;
                                    }
                                    out_col[aind_a[i]]     -= dot0;
                                    out_col[aind_a[i + 1]] -= dot1;
                                }
                                if (i < cols_a) {
                                    const double* __restrict__ col_a_i = chunk_a + static_cast<std::size_t>(i) * rows_a;
                                    double dot = 0.0;
                                    #pragma omp simd reduction(+:dot)
                                    for (int r = 0; r < rows_a; ++r) dot += col_a_i[r] * col_b_j[r];
                                    out_col[aind_a[i]] -= dot;
                                }
                            }

                        } else if (path_flag == 3) {
                            // BLAS + contiguous scatter — inline SIMD axpy avoids cblas_daxpy call overhead
                            const int ld_tmp = cols_a;
                            const int a_start = semi_a.fa;
                            const int32_t* slots = scatter_packed + data_off;
                            sTiles::core_dgemm(sTiles::Op::Trans, sTiles::Op::NoTrans,
                                            cols_a, cols_b, rows_a,
                                            mzone, chunk_a, rows_a, chunk_b, rows_a,
                                            0.0, tmp_tile, ld_tmp);
                            for (int j = 0; j < cols_b; ++j) {
                                const int slot = slots[j];
                                if (slot < 0) continue;
                                double* __restrict__ out_col = chunk_out + static_cast<std::size_t>(slot) * rows_out + a_start;
                                const double* __restrict__ tmp_col = tmp_tile + j * ld_tmp;
                                #pragma omp simd
                                for (int i = 0; i < cols_a; ++i) out_col[i] += tmp_col[i];
                            }

                        } else if (path_flag == 4) {
                            // BLAS + indexed scatter
                            const int ld_tmp = cols_a;
                            const int* __restrict__ aind_a = semi_a.aind.data();
                            const int32_t* slots = scatter_packed + data_off;
                            sTiles::core_dgemm(sTiles::Op::Trans, sTiles::Op::NoTrans,
                                            cols_a, cols_b, rows_a,
                                            mzone, chunk_a, rows_a, chunk_b, rows_a,
                                            0.0, tmp_tile, ld_tmp);
                            for (int j = 0; j < cols_b; ++j) {
                                const int slot = slots[j];
                                if (slot < 0) continue;
                                double* __restrict__ out_col = chunk_out + static_cast<std::size_t>(slot) * rows_out;
                                const double* __restrict__ tmp_col = tmp_tile + j * ld_tmp;
                                int i = 0;
                                for (; i + 3 < cols_a; i += 4) {
                                    out_col[aind_a[i]]     += tmp_col[i];
                                    out_col[aind_a[i + 1]] += tmp_col[i + 1];
                                    out_col[aind_a[i + 2]] += tmp_col[i + 2];
                                    out_col[aind_a[i + 3]] += tmp_col[i + 3];
                                }
                                for (; i < cols_a; ++i) out_col[aind_a[i]] += tmp_col[i];
                            }
                        }
                        break;
                    }

                    case 1: { // DPOTRF — banded Cholesky on diagonal tile
                        // Diagonal tile: chunked_tiles[index1] is allocated with elems = height*(upper_bw+1),
                        // so it's never null for an active diagonal — no null guard needed.
                        double* __restrict__ tile_out = chunked_tiles[index1];
                        const sTiles::SemisparseTileMetaCore& semi = semisparse_meta[index1];
                        const sTiles::TileMetaCore& meta = tile_meta[index1];
                        sTiles::StatusCode ssstatus = sTiles::core_dpotrf_upper_banded(meta.height, semi.upper_bw, tile_out);
                        if (ssstatus != sTiles::StatusCode::Success) {
                            std::fprintf(stderr, "sTiles error: matrix is not positive definite (banded tile k=%d).\n", t[2]);
                            return;
                        }
                        break;
                    }

                    case 2: { // DSYRK — symmetric rank-k update into banded diagonal
                        // chunked_tiles[idx]==nullptr ⇔ semi.sa==0 (see allocate_semisparse_tiles),
                        // so the active_cols>0 check subsumes a tile_in null guard. tile_out is the
                        // diagonal, never null.
                        const sTiles::SemisparseTileMetaCore& semi_in = semisparse_meta[index1];
                        const int active_cols = semi_in.sa;
                        if (active_cols > 0) {
                            double* __restrict__ tile_in  = chunked_tiles[index1];
                            double* __restrict__ tile_out = chunked_tiles[index2];
                            const sTiles::SemisparseTileMetaCore& semi_out = semisparse_meta[index2];
                            const int diag_cols = semi_out.upper_bw + 1;
                            const int rows_in = (tile_meta[index1].height > 0) ? tile_meta[index1].height : tile_size;
                            const int base_row = diag_cols - 1;

                            const bool aind_contig = semi_in.is_contiguous;

                            if (active_cols <= FUSE_THRESHOLD && aind_contig && active_cols <= diag_cols) {
                                const int aind_start = semi_in.fa;
                                for (int j = 0; j < active_cols; ++j) {
                                    const int col_idx = aind_start + j;
                                    const std::size_t col_base = static_cast<std::size_t>(diag_cols) * col_idx;
                                    const double* __restrict__ col_j = tile_in + static_cast<std::size_t>(j) * rows_in;
                                    for (int i = 0; i <= j; ++i) {
                                        const double* __restrict__ col_i = tile_in + static_cast<std::size_t>(i) * rows_in;
                                        double dot = 0.0;
                                        #pragma omp simd reduction(+:dot)
                                        for (int r = 0; r < rows_in; ++r) dot += col_i[r] * col_j[r];
                                        tile_out[base_row - (j - i) + col_base] -= dot;
                                    }
                                }
                            } else if (active_cols <= FUSE_THRESHOLD) {
                                const int* __restrict__ aind = semi_in.aind.data();
                                for (int j = 0; j < active_cols; ++j) {
                                    const int col_idx = aind[j];
                                    const std::size_t col_base = static_cast<std::size_t>(diag_cols) * col_idx;
                                    const double* __restrict__ col_j = tile_in + static_cast<std::size_t>(j) * rows_in;
                                    for (int i = 0; i <= j; ++i) {
                                        const int band = col_idx - aind[i];
                                        if (band < diag_cols) {
                                            const double* __restrict__ col_i = tile_in + static_cast<std::size_t>(i) * rows_in;
                                            double dot = 0.0;
                                            #pragma omp simd reduction(+:dot)
                                            for (int r = 0; r < rows_in; ++r) dot += col_i[r] * col_j[r];
                                            tile_out[base_row - band + col_base] -= dot;
                                        }
                                    }
                                }
                            } else if (aind_contig && active_cols <= diag_cols) {
                                const int ld_tmp = active_cols;
                                sTiles::core_dsyrk(sTiles::Uplo::Upper, sTiles::Op::Trans,
                                                active_cols, rows_in, mzone,
                                                tile_in, rows_in, 0.0, tmp_tile, ld_tmp);
                                const int aind_start = semi_in.fa;
                                for (int j = 0; j < active_cols; ++j) {
                                    const int col_idx = aind_start + j;
                                    const std::size_t col_base = static_cast<std::size_t>(diag_cols) * col_idx;
                                    const double* __restrict__ tmp_col = tmp_tile + j * ld_tmp;
                                    for (int i = 0; i <= j; ++i)
                                        tile_out[base_row - (j - i) + col_base] += tmp_col[i];
                                }
                            } else {
                                const int ld_tmp = active_cols;
                                const int* __restrict__ aind = semi_in.aind.data();
                                sTiles::core_dsyrk(sTiles::Uplo::Upper, sTiles::Op::Trans,
                                                active_cols, rows_in, mzone,
                                                tile_in, rows_in, 0.0, tmp_tile, ld_tmp);
                                for (int j = 0; j < active_cols; ++j) {
                                    const int col_idx = aind[j];
                                    const std::size_t col_base = static_cast<std::size_t>(diag_cols) * col_idx;
                                    const double* __restrict__ tmp_col = tmp_tile + j * ld_tmp;
                                    for (int i = 0; i <= j; ++i) {
                                        const int band = col_idx - aind[i];
                                        if (band < diag_cols)
                                            tile_out[base_row - band + col_base] += tmp_col[i];
                                    }
                                }
                            }
                        }
                        break;
                    }

                    case 3: { // DTRSM — banded triangular solve
                        // Same invariant as case 2: ss_rhs is null iff active_cols==0.
                        // ss_diag is the diagonal, never null. Single guard suffices.
                        const sTiles::SemisparseTileMetaCore& semi_rhs = semisparse_meta[index1];
                        const int active_cols = semi_rhs.sa;
                        if (active_cols > 0) {
                            double* __restrict__ ss_rhs  = chunked_tiles[index1];
                            double* __restrict__ ss_diag = chunked_tiles[index2];
                            const sTiles::SemisparseTileMetaCore& semi_diag = semisparse_meta[index2];
                            const int rows_rhs = tile_meta[index1].height;
                            const int diag_dim = tile_meta[index2].height;
                            const int kd = semi_diag.upper_bw;

                            lapack_int info = LAPACKE_dtbtrs(LAPACK_COL_MAJOR, 'U', 'T', 'N',
                                                            diag_dim, kd, active_cols,
                                                            ss_diag, kd + 1, ss_rhs, rows_rhs);
                            if (info != 0) {
                                std::fprintf(stderr, "sTiles error: LAPACKE_dtbtrs failed with info=%d (tile m=%d, k=%d)\n",
                                            info, t[1], t[2]);
                                return;
                            }
                        }
                        break;
                    }

                    default:
                        break;
                }
            }
        }

        void omp_dpotrf_expansion_semi_serial_imp4(TiledMatrix* tiledMatrix, omp_dep_tracker_t* dep_tracker) {
            // OMP single-thread mirror of pthreads_dpotrf_expansion_semi_serial_imp4.
            // No inter-task sync needed (one thread runs the whole task list);
            // dep_tracker is kept on the signature for the dispatcher's abort
            // protocol — set abort_flag on a non-PD failure and bail out.
            (void)dep_tracker;
            const int rank = omp_get_thread_num();

            double** __restrict__ const chunked_tiles = tiledMatrix->chunkedDenseTiles;
            const sTiles::SemisparseTileMetaCore* __restrict__ const semisparse_meta = tiledMatrix->semisparseTileMetaCore;
            const sTiles::TileMetaCore* __restrict__ const tile_meta = tiledMatrix->tileMetaCore;

            const auto &tasks = sTiles::get_chol_tasks(tiledMatrix);
            const int start = 0;
            const int end = static_cast<int>(tasks.size());

            if (rank >= tiledMatrix->num_workspaces) {
                sTiles::Logger::error("[semi_serial_imp4_omp] rank ", rank, " >= num_workspaces ", tiledMatrix->num_workspaces);
                return;
            }
            double* __restrict__ tmp_tile = tiledMatrix->workspaces[rank]->aligned_tile();
            const double mzone = -1.0;

            constexpr int FUSE_THRESHOLD = 16;

            const int ntiles_bounds = tiledMatrix->numActiveTiles;
            const int tile_size = tiledMatrix->tile_size;

            const int64_t* scatter_index = tiledMatrix->chol_scatter_index->data();
            const int32_t* scatter_packed = tiledMatrix->chol_scatter_packed->data();

            for (int idx = start; idx < end; ++idx) {
                const std::array<int,7> &t = tasks[idx];
                const int myroutine = t[0];
                const int index1 = t[4];
                const int index2 = t[5];
                const int index3 = t[6];

                if (idx + 1 < end) {
                    const std::array<int,7> &next_t = tasks[idx + 1];
                    const int next_routine = next_t[0];
                    const int next_idx1 = next_t[4];
                    const int next_idx2 = next_t[5];
                    if (next_idx1 >= 0 && next_idx1 < ntiles_bounds && chunked_tiles[next_idx1]) {
                        __builtin_prefetch(chunked_tiles[next_idx1], 0, 2);
                    }
                    if (next_idx2 >= 0 && next_idx2 < ntiles_bounds && chunked_tiles[next_idx2]) {
                        __builtin_prefetch(chunked_tiles[next_idx2], 1, 2);
                    }
                    if (next_routine == 4) {
                        const int next_idx3 = next_t[6];
                        if (next_idx3 >= 0 && next_idx3 < ntiles_bounds && chunked_tiles[next_idx3]) {
                            __builtin_prefetch(chunked_tiles[next_idx3], 1, 2);
                        }
                        const int64_t next_si = static_cast<int64_t>(idx + 1) * 2;
                        __builtin_prefetch(&scatter_index[next_si], 0, 3);
                        const int64_t next_data_off = scatter_index[next_si];
                        if (next_data_off >= 0) {
                            __builtin_prefetch(scatter_packed + next_data_off, 0, 3);
                        }
                    }
                    __builtin_prefetch(&semisparse_meta[next_idx1], 0, 3);
                    __builtin_prefetch(&semisparse_meta[next_idx2], 0, 3);
                    if (next_idx1 >= 0 && next_idx1 < ntiles_bounds) {
                        const int* aind_ptr = semisparse_meta[next_idx1].aind.data();
                        if (aind_ptr) __builtin_prefetch(aind_ptr, 0, 2);
                    }
                }

                switch (myroutine) {

                    case 4: { // DGEMM — C(k,m) -= A(n,k)^T * B(n,m)
                        double* __restrict__ chunk_a = chunked_tiles[index1];
                        double* __restrict__ chunk_b = chunked_tiles[index2];
                        double* __restrict__ chunk_out = chunked_tiles[index3];

                        const sTiles::SemisparseTileMetaCore& semi_a = semisparse_meta[index1];
                        const sTiles::SemisparseTileMetaCore& semi_b = semisparse_meta[index2];

                        const int cols_a = semi_a.sa;
                        const int cols_b = semi_b.sa;
                        const int rows_a = tile_meta[index1].height;
                        const int rows_out = tile_meta[index3].height;

                        const int si_base = idx * 2;
                        const int64_t data_off  = scatter_index[si_base];
                        const int path_flag = static_cast<int>(scatter_index[si_base + 1]);

                        if (path_flag == 0) {
                            const int a_start = semi_a.fa;
                            const int b_start = semi_b.fa;
                            cblas_dgemm(CblasColMajor, CblasTrans, CblasNoTrans,
                                        cols_a, cols_b, rows_a, mzone,
                                        chunk_a, rows_a, chunk_b, rows_a,
                                        1.0, chunk_out + a_start + static_cast<std::size_t>(b_start) * rows_out, rows_out);

                        } else if (path_flag == 1) {
                            const int a_start = semi_a.fa;
                            const int32_t* slots = scatter_packed + data_off;
                            const int cols_a_pair = cols_a & ~1;
                            for (int j = 0; j < cols_b; ++j) {
                                const int slot = slots[j];
                                if (slot < 0) continue;
                                double* __restrict__ out_col = chunk_out + static_cast<std::size_t>(slot) * rows_out + a_start;
                                const double* __restrict__ col_b_j = chunk_b + static_cast<std::size_t>(j) * rows_a;
                                int i = 0;
                                for (; i < cols_a_pair; i += 2) {
                                    const double* __restrict__ col_a_i0 = chunk_a + static_cast<std::size_t>(i)     * rows_a;
                                    const double* __restrict__ col_a_i1 = chunk_a + static_cast<std::size_t>(i + 1) * rows_a;
                                    double dot0 = 0.0, dot1 = 0.0;
                                    #pragma omp simd reduction(+:dot0,dot1)
                                    for (int r = 0; r < rows_a; ++r) {
                                        const double bv = col_b_j[r];
                                        dot0 += col_a_i0[r] * bv;
                                        dot1 += col_a_i1[r] * bv;
                                    }
                                    out_col[i]     -= dot0;
                                    out_col[i + 1] -= dot1;
                                }
                                if (i < cols_a) {
                                    const double* __restrict__ col_a_i = chunk_a + static_cast<std::size_t>(i) * rows_a;
                                    double dot = 0.0;
                                    #pragma omp simd reduction(+:dot)
                                    for (int r = 0; r < rows_a; ++r) dot += col_a_i[r] * col_b_j[r];
                                    out_col[i] -= dot;
                                }
                            }

                        } else if (path_flag == 2) {
                            const int* __restrict__ aind_a = semi_a.aind.data();
                            const int32_t* slots = scatter_packed + data_off;
                            const int cols_a_pair = cols_a & ~1;
                            for (int j = 0; j < cols_b; ++j) {
                                const int slot = slots[j];
                                if (slot < 0) continue;
                                double* __restrict__ out_col = chunk_out + static_cast<std::size_t>(slot) * rows_out;
                                const double* __restrict__ col_b_j = chunk_b + static_cast<std::size_t>(j) * rows_a;
                                int i = 0;
                                for (; i < cols_a_pair; i += 2) {
                                    const double* __restrict__ col_a_i0 = chunk_a + static_cast<std::size_t>(i)     * rows_a;
                                    const double* __restrict__ col_a_i1 = chunk_a + static_cast<std::size_t>(i + 1) * rows_a;
                                    double dot0 = 0.0, dot1 = 0.0;
                                    #pragma omp simd reduction(+:dot0,dot1)
                                    for (int r = 0; r < rows_a; ++r) {
                                        const double bv = col_b_j[r];
                                        dot0 += col_a_i0[r] * bv;
                                        dot1 += col_a_i1[r] * bv;
                                    }
                                    out_col[aind_a[i]]     -= dot0;
                                    out_col[aind_a[i + 1]] -= dot1;
                                }
                                if (i < cols_a) {
                                    const double* __restrict__ col_a_i = chunk_a + static_cast<std::size_t>(i) * rows_a;
                                    double dot = 0.0;
                                    #pragma omp simd reduction(+:dot)
                                    for (int r = 0; r < rows_a; ++r) dot += col_a_i[r] * col_b_j[r];
                                    out_col[aind_a[i]] -= dot;
                                }
                            }

                        } else if (path_flag == 3) {
                            const int ld_tmp = cols_a;
                            const int a_start = semi_a.fa;
                            const int32_t* slots = scatter_packed + data_off;
                            sTiles::core_dgemm(sTiles::Op::Trans, sTiles::Op::NoTrans,
                                            cols_a, cols_b, rows_a,
                                            mzone, chunk_a, rows_a, chunk_b, rows_a,
                                            0.0, tmp_tile, ld_tmp);
                            for (int j = 0; j < cols_b; ++j) {
                                const int slot = slots[j];
                                if (slot < 0) continue;
                                double* __restrict__ out_col = chunk_out + static_cast<std::size_t>(slot) * rows_out + a_start;
                                const double* __restrict__ tmp_col = tmp_tile + j * ld_tmp;
                                #pragma omp simd
                                for (int i = 0; i < cols_a; ++i) out_col[i] += tmp_col[i];
                            }

                        } else if (path_flag == 4) {
                            const int ld_tmp = cols_a;
                            const int* __restrict__ aind_a = semi_a.aind.data();
                            const int32_t* slots = scatter_packed + data_off;
                            sTiles::core_dgemm(sTiles::Op::Trans, sTiles::Op::NoTrans,
                                            cols_a, cols_b, rows_a,
                                            mzone, chunk_a, rows_a, chunk_b, rows_a,
                                            0.0, tmp_tile, ld_tmp);
                            for (int j = 0; j < cols_b; ++j) {
                                const int slot = slots[j];
                                if (slot < 0) continue;
                                double* __restrict__ out_col = chunk_out + static_cast<std::size_t>(slot) * rows_out;
                                const double* __restrict__ tmp_col = tmp_tile + j * ld_tmp;
                                int i = 0;
                                for (; i + 3 < cols_a; i += 4) {
                                    out_col[aind_a[i]]     += tmp_col[i];
                                    out_col[aind_a[i + 1]] += tmp_col[i + 1];
                                    out_col[aind_a[i + 2]] += tmp_col[i + 2];
                                    out_col[aind_a[i + 3]] += tmp_col[i + 3];
                                }
                                for (; i < cols_a; ++i) out_col[aind_a[i]] += tmp_col[i];
                            }
                        }
                        break;
                    }

                    case 1: { // DPOTRF — banded Cholesky on diagonal tile
                        double* __restrict__ tile_out = chunked_tiles[index1];
                        const sTiles::SemisparseTileMetaCore& semi = semisparse_meta[index1];
                        const sTiles::TileMetaCore& meta = tile_meta[index1];
                        sTiles::StatusCode ssstatus = sTiles::core_dpotrf_upper_banded(meta.height, semi.upper_bw, tile_out);
                        if (ssstatus != sTiles::StatusCode::Success) {
                            std::fprintf(stderr, "sTiles error: matrix is not positive definite (banded tile k=%d).\n", t[2]);
                            dep_tracker->abort_flag.store(true, std::memory_order_release);
                            return;
                        }
                        break;
                    }

                    case 2: { // DSYRK — symmetric rank-k update into banded diagonal
                        const sTiles::SemisparseTileMetaCore& semi_in = semisparse_meta[index1];
                        const int active_cols = semi_in.sa;
                        if (active_cols > 0) {
                            double* __restrict__ tile_in  = chunked_tiles[index1];
                            double* __restrict__ tile_out = chunked_tiles[index2];
                            const sTiles::SemisparseTileMetaCore& semi_out = semisparse_meta[index2];
                            const int diag_cols = semi_out.upper_bw + 1;
                            const int rows_in = (tile_meta[index1].height > 0) ? tile_meta[index1].height : tile_size;
                            const int base_row = diag_cols - 1;

                            const bool aind_contig = semi_in.is_contiguous;

                            if (active_cols <= FUSE_THRESHOLD && aind_contig && active_cols <= diag_cols) {
                                const int aind_start = semi_in.fa;
                                for (int j = 0; j < active_cols; ++j) {
                                    const int col_idx = aind_start + j;
                                    const std::size_t col_base = static_cast<std::size_t>(diag_cols) * col_idx;
                                    const double* __restrict__ col_j = tile_in + static_cast<std::size_t>(j) * rows_in;
                                    for (int i = 0; i <= j; ++i) {
                                        const double* __restrict__ col_i = tile_in + static_cast<std::size_t>(i) * rows_in;
                                        double dot = 0.0;
                                        #pragma omp simd reduction(+:dot)
                                        for (int r = 0; r < rows_in; ++r) dot += col_i[r] * col_j[r];
                                        tile_out[base_row - (j - i) + col_base] -= dot;
                                    }
                                }
                            } else if (active_cols <= FUSE_THRESHOLD) {
                                const int* __restrict__ aind = semi_in.aind.data();
                                for (int j = 0; j < active_cols; ++j) {
                                    const int col_idx = aind[j];
                                    const std::size_t col_base = static_cast<std::size_t>(diag_cols) * col_idx;
                                    const double* __restrict__ col_j = tile_in + static_cast<std::size_t>(j) * rows_in;
                                    for (int i = 0; i <= j; ++i) {
                                        const int band = col_idx - aind[i];
                                        if (band < diag_cols) {
                                            const double* __restrict__ col_i = tile_in + static_cast<std::size_t>(i) * rows_in;
                                            double dot = 0.0;
                                            #pragma omp simd reduction(+:dot)
                                            for (int r = 0; r < rows_in; ++r) dot += col_i[r] * col_j[r];
                                            tile_out[base_row - band + col_base] -= dot;
                                        }
                                    }
                                }
                            } else if (aind_contig && active_cols <= diag_cols) {
                                const int ld_tmp = active_cols;
                                sTiles::core_dsyrk(sTiles::Uplo::Upper, sTiles::Op::Trans,
                                                active_cols, rows_in, mzone,
                                                tile_in, rows_in, 0.0, tmp_tile, ld_tmp);
                                const int aind_start = semi_in.fa;
                                for (int j = 0; j < active_cols; ++j) {
                                    const int col_idx = aind_start + j;
                                    const std::size_t col_base = static_cast<std::size_t>(diag_cols) * col_idx;
                                    const double* __restrict__ tmp_col = tmp_tile + j * ld_tmp;
                                    for (int i = 0; i <= j; ++i)
                                        tile_out[base_row - (j - i) + col_base] += tmp_col[i];
                                }
                            } else {
                                const int ld_tmp = active_cols;
                                const int* __restrict__ aind = semi_in.aind.data();
                                sTiles::core_dsyrk(sTiles::Uplo::Upper, sTiles::Op::Trans,
                                                active_cols, rows_in, mzone,
                                                tile_in, rows_in, 0.0, tmp_tile, ld_tmp);
                                for (int j = 0; j < active_cols; ++j) {
                                    const int col_idx = aind[j];
                                    const std::size_t col_base = static_cast<std::size_t>(diag_cols) * col_idx;
                                    const double* __restrict__ tmp_col = tmp_tile + j * ld_tmp;
                                    for (int i = 0; i <= j; ++i) {
                                        const int band = col_idx - aind[i];
                                        if (band < diag_cols)
                                            tile_out[base_row - band + col_base] += tmp_col[i];
                                    }
                                }
                            }
                        }
                        break;
                    }

                    case 3: { // DTRSM — banded triangular solve
                        const sTiles::SemisparseTileMetaCore& semi_rhs = semisparse_meta[index1];
                        const int active_cols = semi_rhs.sa;
                        if (active_cols > 0) {
                            double* __restrict__ ss_rhs  = chunked_tiles[index1];
                            double* __restrict__ ss_diag = chunked_tiles[index2];
                            const sTiles::SemisparseTileMetaCore& semi_diag = semisparse_meta[index2];
                            const int rows_rhs = tile_meta[index1].height;
                            const int diag_dim = tile_meta[index2].height;
                            const int kd = semi_diag.upper_bw;

                            lapack_int info = LAPACKE_dtbtrs(LAPACK_COL_MAJOR, 'U', 'T', 'N',
                                                            diag_dim, kd, active_cols,
                                                            ss_diag, kd + 1, ss_rhs, rows_rhs);
                            if (info != 0) {
                                std::fprintf(stderr, "sTiles error: LAPACKE_dtbtrs failed with info=%d (tile m=%d, k=%d)\n",
                                            info, t[1], t[2]);
                                dep_tracker->abort_flag.store(true, std::memory_order_release);
                                return;
                            }
                        }
                        break;
                    }

                    default:
                        break;
                }
            }
        }

        void pthreads_dpotrf_expansion_semi_parallel_imp4(TiledMatrix *tiledMatrix, stiles_context_t *stile) {
            // imp4 = imp3 + memory/core-model improvements:
            //   (a) #pragma omp simd reduction on hand-rolled dot loops (cases 4-p1/p2, 2-fused)
            //   (b) 2-column-of-A blocking in cases 4-p1/p2 → reuses col_b_j register, ~halves B traffic
            //   (c) Smarter prefetch: drops redundant 4×64B tile-head reads, prefetches metadata,
            //       scatter_packed[next_data_off], and aind data of next semisparse meta
            //   (d) Single load of next-task scatter_index pair (cache line warmup)
            //   (e) Hoists tile_meta[*].height to scalars before hot loops
            // Numerics, semantics, and dependency protocol are identical to imp3.

            const int rank = STILES_RANK;
            const int N = tiledMatrix->dim;
            const int tile_size = tiledMatrix->tile_size;
            const int num_tiles_per_dim = (N == 0) ? 0 : (N - 1) / tile_size + 1;

            double** __restrict__ const chunked_tiles = tiledMatrix->chunkedDenseTiles;
            const sTiles::SemisparseTileMetaCore* __restrict__ const semisparse_meta = tiledMatrix->semisparseTileMetaCore;
            const sTiles::TileMetaCore* __restrict__ const tile_meta = tiledMatrix->tileMetaCore;

            const auto &tasks = sTiles::get_chol_tasks(tiledMatrix);
            const auto &offsets = sTiles::get_chol_task_offsets(tiledMatrix);
            const int start = (rank < static_cast<int>(offsets.size())) ? offsets[rank] : 0;
            const int end = (rank + 1 < static_cast<int>(offsets.size())) ? offsets[rank + 1] : static_cast<int>(tasks.size());

            if (rank >= tiledMatrix->num_workspaces) {
                sTiles::Logger::error("[semisparse_imp4] rank ", rank, " >= num_workspaces ", tiledMatrix->num_workspaces);
                return;
            }
            double* __restrict__ tmp_tile = tiledMatrix->workspaces[rank]->aligned_tile();
            const double mzone = -1.0;

            // DSYRK fuse crossover: below this many active columns, use the hand-rolled
            // SIMD path instead of the library core_dsyrk. The optimal cutoff is
            // CPU-dependent, so pick it automatically:
            //   - AMD/EPYC: vendor BLAS underperforms on tiny updates → always fuse
            //     (active_cols <= tile_size, so a huge value = "always fused").
            //   - Intel: MKL wins above ~16 → keep the tuned crossover.
            // STILES_FUSE_THRESHOLD env var overrides the auto choice (for tuning/sweeps).
            static const int FUSE_THRESHOLD = []() {
                if (const char* v = std::getenv("STILES_FUSE_THRESHOLD")) {
                    int x = std::atoi(v);
                    if (x >= 0) return x;
                }
                __builtin_cpu_init();
                return __builtin_cpu_is("amd") ? (1 << 20) : 16;
            }();

            const int64_t* scatter_index = tiledMatrix->chol_scatter_index->data();
            const int32_t* scatter_packed = tiledMatrix->chol_scatter_packed->data();

            const double _ss_init_t0 = omp_get_wtime();
            ss_init_dp(tiledMatrix, num_tiles_per_dim, tiledMatrix->numActiveTiles, 0);
            const double _ss_init_dt = omp_get_wtime() - _ss_init_t0;

            const int ntiles_bounds = tiledMatrix->numActiveTiles;

            const bool _stiles_dump_pt = []() {
                const char* v = std::getenv("STILES_DUMP_TASKS");
                return v && std::atoi(v) != 0;
            }();
            if (_stiles_dump_pt && rank == 0) {
                std::fprintf(stderr, "[STILES_DUMP/pthreads_expansion_semi] total_chol_tasks=%d  worldsize=%d  num_tiles_per_dim=%d  numActiveTiles=%d  offsets.size=%zu  ss_init_dt=%.4fs\n",
                             static_cast<int>(tasks.size()), stile ? stile->world_size : -1,
                             num_tiles_per_dim, tiledMatrix->numActiveTiles, offsets.size(),
                             _ss_init_dt);
            }
            int _dump_pt_routine_count[5] = {0,0,0,0,0};
            const double _dump_pt_t0 = _stiles_dump_pt ? omp_get_wtime() : 0.0;

            for (int idx = start; idx < end; ++idx) {
                const std::array<int,7> &t = tasks[idx];
                const int myroutine = t[0];
                const int m = t[1];
                const int k = t[2];
                const int n = t[3];
                const int index1 = t[4];
                const int index2 = t[5];
                const int index3 = t[6];

                if (_stiles_dump_pt && myroutine >= 0 && myroutine < 5) {
                    _dump_pt_routine_count[myroutine]++;
                }

                // ── (c)+(d) Prefetch: focus on first cache line of each tile (metadata is already
                // in registers by the time we touch the body), plus the indirection arrays
                // (scatter_packed, aind) that drive the scatter — those are unpredictable loads
                // and benefit most from prefetch. Use _MM_HINT_T1 (==2) to land in L2 and avoid
                // L1 thrash with the current task's working set.
                if (idx + 1 < end) {
                    const std::array<int,7> &next_t = tasks[idx + 1];
                    const int next_routine = next_t[0];
                    const int next_idx1 = next_t[4];
                    const int next_idx2 = next_t[5];

                    if (next_idx1 >= 0 && next_idx1 < ntiles_bounds && chunked_tiles[next_idx1]) {
                        __builtin_prefetch(chunked_tiles[next_idx1], 0, 2);
                    }
                    if (next_idx2 >= 0 && next_idx2 < ntiles_bounds && chunked_tiles[next_idx2]) {
                        __builtin_prefetch(chunked_tiles[next_idx2], 1, 2);
                    }
                    if (next_routine == 4) {
                        const int next_idx3 = next_t[6];
                        if (next_idx3 >= 0 && next_idx3 < ntiles_bounds && chunked_tiles[next_idx3]) {
                            __builtin_prefetch(chunked_tiles[next_idx3], 1, 2);
                        }
                        // Indirection arrays for the next case-4 dispatch
                        const int64_t next_si = static_cast<int64_t>(idx + 1) * 2;
                        __builtin_prefetch(&scatter_index[next_si], 0, 3);
                        const int64_t next_data_off = scatter_index[next_si];
                        if (next_data_off >= 0) {
                            __builtin_prefetch(scatter_packed + next_data_off, 0, 3);
                        }
                    }
                    __builtin_prefetch(&semisparse_meta[next_idx1], 0, 3);
                    __builtin_prefetch(&semisparse_meta[next_idx2], 0, 3);
                    // aind backing data for next semis (the vector header is in the meta cache line,
                    // but the heap-allocated int array is a separate line)
                    if (next_idx1 >= 0 && next_idx1 < ntiles_bounds) {
                        const int* aind_ptr = semisparse_meta[next_idx1].aind.data();
                        if (aind_ptr) __builtin_prefetch(aind_ptr, 0, 2);
                    }
                }

                switch (myroutine) {

                    case 4: { // DGEMM — C(k,m) -= A(n,k)^T * B(n,m)
                        // (k,n) is tile A → index1; (m,n) is tile B → index2.
                        SS_WAIT_DP(k, n, index1, 1);
                        SS_WAIT_DP(m, n, index2, 1);

                        double* __restrict__ chunk_out = chunked_tiles[index3];
                        const int rows_out = tile_meta[index3].height;

                        double* __restrict__ chunk_a = chunked_tiles[index1];
                        double* __restrict__ chunk_b = chunked_tiles[index2];

                        const sTiles::SemisparseTileMetaCore& semi_a = semisparse_meta[index1];
                        const sTiles::SemisparseTileMetaCore& semi_b = semisparse_meta[index2];

                        const int cols_a = semi_a.sa;
                        const int cols_b = semi_b.sa;
                        const int rows_a = tile_meta[index1].height;

                        const int si_base = idx * 2;
                        const int64_t data_off  = scatter_index[si_base];
                        const int path_flag = static_cast<int>(scatter_index[si_base + 1]);

                        if (path_flag == 0) {
                            const int a_start = semi_a.fa;
                            const int b_start = semi_b.fa;
                            cblas_dgemm(CblasColMajor, CblasTrans, CblasNoTrans,
                                        cols_a, cols_b, rows_a, mzone,
                                        chunk_a, rows_a, chunk_b, rows_a,
                                        1.0, chunk_out + a_start + static_cast<std::size_t>(b_start) * rows_out, rows_out);

                        } else if (path_flag == 1) {
                            // (a) vectorize dot, (b) 2-i blocking: process A-cols (i, i+1) against
                            // a single B-col → halves loads of col_b_j. Tail handles odd cols_a.
                            const int a_start = semi_a.fa;
                            const int32_t* slots = scatter_packed + data_off;
                            const int cols_a_pair = cols_a & ~1;
                            for (int j = 0; j < cols_b; ++j) {
                                const int slot = slots[j];
                                if (slot < 0) continue;
                                double* __restrict__ out_col = chunk_out + static_cast<std::size_t>(slot) * rows_out + a_start;
                                const double* __restrict__ col_b_j = chunk_b + static_cast<std::size_t>(j) * rows_a;
                                int i = 0;
                                for (; i < cols_a_pair; i += 2) {
                                    const double* __restrict__ col_a_i0 = chunk_a + static_cast<std::size_t>(i)     * rows_a;
                                    const double* __restrict__ col_a_i1 = chunk_a + static_cast<std::size_t>(i + 1) * rows_a;
                                    double dot0 = 0.0, dot1 = 0.0;
                                    #pragma omp simd reduction(+:dot0,dot1)
                                    for (int r = 0; r < rows_a; ++r) {
                                        const double bv = col_b_j[r];
                                        dot0 += col_a_i0[r] * bv;
                                        dot1 += col_a_i1[r] * bv;
                                    }
                                    out_col[i]     -= dot0;
                                    out_col[i + 1] -= dot1;
                                }
                                if (i < cols_a) {
                                    const double* __restrict__ col_a_i = chunk_a + static_cast<std::size_t>(i) * rows_a;
                                    double dot = 0.0;
                                    #pragma omp simd reduction(+:dot)
                                    for (int r = 0; r < rows_a; ++r) dot += col_a_i[r] * col_b_j[r];
                                    out_col[i] -= dot;
                                }
                            }

                        } else if (path_flag == 2) {
                            const int* __restrict__ aind_a = semi_a.aind.data();
                            const int32_t* slots = scatter_packed + data_off;
                            const int cols_a_pair = cols_a & ~1;
                            for (int j = 0; j < cols_b; ++j) {
                                const int slot = slots[j];
                                if (slot < 0) continue;
                                double* __restrict__ out_col = chunk_out + static_cast<std::size_t>(slot) * rows_out;
                                const double* __restrict__ col_b_j = chunk_b + static_cast<std::size_t>(j) * rows_a;
                                int i = 0;
                                for (; i < cols_a_pair; i += 2) {
                                    const double* __restrict__ col_a_i0 = chunk_a + static_cast<std::size_t>(i)     * rows_a;
                                    const double* __restrict__ col_a_i1 = chunk_a + static_cast<std::size_t>(i + 1) * rows_a;
                                    double dot0 = 0.0, dot1 = 0.0;
                                    #pragma omp simd reduction(+:dot0,dot1)
                                    for (int r = 0; r < rows_a; ++r) {
                                        const double bv = col_b_j[r];
                                        dot0 += col_a_i0[r] * bv;
                                        dot1 += col_a_i1[r] * bv;
                                    }
                                    out_col[aind_a[i]]     -= dot0;
                                    out_col[aind_a[i + 1]] -= dot1;
                                }
                                if (i < cols_a) {
                                    const double* __restrict__ col_a_i = chunk_a + static_cast<std::size_t>(i) * rows_a;
                                    double dot = 0.0;
                                    #pragma omp simd reduction(+:dot)
                                    for (int r = 0; r < rows_a; ++r) dot += col_a_i[r] * col_b_j[r];
                                    out_col[aind_a[i]] -= dot;
                                }
                            }

                        } else if (path_flag == 3) {
                            const int ld_tmp = cols_a;
                            const int a_start = semi_a.fa;
                            const int32_t* slots = scatter_packed + data_off;
                            sTiles::core_dgemm(sTiles::Op::Trans, sTiles::Op::NoTrans,
                                            cols_a, cols_b, rows_a,
                                            mzone, chunk_a, rows_a, chunk_b, rows_a,
                                            0.0, tmp_tile, ld_tmp);
                            for (int j = 0; j < cols_b; ++j) {
                                const int slot = slots[j];
                                if (slot < 0) continue;
                                double* __restrict__ out_col = chunk_out + static_cast<std::size_t>(slot) * rows_out + a_start;
                                const double* __restrict__ tmp_col = tmp_tile + j * ld_tmp;
                                #pragma omp simd
                                for (int i = 0; i < cols_a; ++i) out_col[i] += tmp_col[i];
                            }

                        } else if (path_flag == 4) {
                            const int ld_tmp = cols_a;
                            const int* __restrict__ aind_a = semi_a.aind.data();
                            const int32_t* slots = scatter_packed + data_off;
                            sTiles::core_dgemm(sTiles::Op::Trans, sTiles::Op::NoTrans,
                                            cols_a, cols_b, rows_a,
                                            mzone, chunk_a, rows_a, chunk_b, rows_a,
                                            0.0, tmp_tile, ld_tmp);
                            for (int j = 0; j < cols_b; ++j) {
                                const int slot = slots[j];
                                if (slot < 0) continue;
                                double* __restrict__ out_col = chunk_out + static_cast<std::size_t>(slot) * rows_out;
                                const double* __restrict__ tmp_col = tmp_tile + j * ld_tmp;
                                int i = 0;
                                for (; i + 3 < cols_a; i += 4) {
                                    out_col[aind_a[i]]     += tmp_col[i];
                                    out_col[aind_a[i + 1]] += tmp_col[i + 1];
                                    out_col[aind_a[i + 2]] += tmp_col[i + 2];
                                    out_col[aind_a[i + 3]] += tmp_col[i + 3];
                                }
                                for (; i < cols_a; ++i) out_col[aind_a[i]] += tmp_col[i];
                            }
                        }
                        break;
                    }

                    case 1: { // DPOTRF — banded Cholesky on diagonal tile
                        double* __restrict__ tile_out = chunked_tiles[index1];
                        const sTiles::SemisparseTileMetaCore& semi = semisparse_meta[index1];
                        const sTiles::TileMetaCore& meta = tile_meta[index1];
                        sTiles::StatusCode ssstatus = sTiles::core_dpotrf_upper_banded(meta.height, semi.upper_bw, tile_out);
                        if (ssstatus != sTiles::StatusCode::Success) {
                            std::fprintf(stderr, "sTiles error: matrix is not positive definite (banded tile k=%d).\n", k);
                            ss_abort(); break;
                        }
                        // (k,k) is the diagonal tile → index1 in this case.
                        ss_set_done_dp(k, k, index1, 1);
                        break;
                    }

                    case 2: { // DSYRK — symmetric rank-k update into banded diagonal
                        // (k,n) is the source tile → index1.
                        SS_WAIT_DP(k, n, index1, 1);

                        double* __restrict__ tile_in = chunked_tiles[index1];
                        double* __restrict__ tile_out = chunked_tiles[index2];

                        if (tile_in && tile_out) {
                            const sTiles::SemisparseTileMetaCore& semi_in = semisparse_meta[index1];
                            const int active_cols = semi_in.sa;

                            if (active_cols > 0) {
                                const sTiles::SemisparseTileMetaCore& semi_out = semisparse_meta[index2];
                                const int diag_cols = semi_out.upper_bw + 1;
                                const int rows_in = (tile_meta[index1].height > 0) ? tile_meta[index1].height : tile_size;
                                const int base_row = diag_cols - 1;

                                const bool aind_contig = semi_in.is_contiguous;

                                if (active_cols <= FUSE_THRESHOLD && aind_contig && active_cols <= diag_cols) {
                                    // === FUSED contiguous: vectorized dot products into banded output ===
                                    const int aind_start = semi_in.fa;
                                    for (int j = 0; j < active_cols; ++j) {
                                        const int col_idx = aind_start + j;
                                        const std::size_t col_base = static_cast<std::size_t>(diag_cols) * col_idx;
                                        const double* __restrict__ col_j = tile_in + static_cast<std::size_t>(j) * rows_in;
                                        for (int i = 0; i <= j; ++i) {
                                            const double* __restrict__ col_i = tile_in + static_cast<std::size_t>(i) * rows_in;
                                            double dot = 0.0;
                                            #pragma omp simd reduction(+:dot)
                                            for (int r = 0; r < rows_in; ++r) {
                                                dot += col_i[r] * col_j[r];
                                            }
                                            tile_out[base_row - (j - i) + col_base] -= dot;
                                        }
                                    }

                                } else if (active_cols <= FUSE_THRESHOLD) {
                                    // === FUSED scattered: vectorized dots with aind lookups ===
                                    const int* __restrict__ aind = semi_in.aind.data();
                                    for (int j = 0; j < active_cols; ++j) {
                                        const int col_idx = aind[j];
                                        const std::size_t col_base = static_cast<std::size_t>(diag_cols) * col_idx;
                                        const double* __restrict__ col_j = tile_in + static_cast<std::size_t>(j) * rows_in;
                                        for (int i = 0; i <= j; ++i) {
                                            const int band = col_idx - aind[i];
                                            if (band < diag_cols) {
                                                const double* __restrict__ col_i = tile_in + static_cast<std::size_t>(i) * rows_in;
                                                double dot = 0.0;
                                                #pragma omp simd reduction(+:dot)
                                                for (int r = 0; r < rows_in; ++r) {
                                                    dot += col_i[r] * col_j[r];
                                                }
                                                tile_out[base_row - band + col_base] -= dot;
                                            }
                                        }
                                    }

                                } else if (aind_contig && active_cols <= diag_cols) {
                                    const int ld_tmp = active_cols;
                                    sTiles::core_dsyrk(sTiles::Uplo::Upper, sTiles::Op::Trans,
                                                    active_cols, rows_in, mzone,
                                                    tile_in, rows_in, 0.0, tmp_tile, ld_tmp);

                                    const int aind_start = semi_in.fa;
                                    for (int j = 0; j < active_cols; ++j) {
                                        const int col_idx = aind_start + j;
                                        const std::size_t col_base = static_cast<std::size_t>(diag_cols) * col_idx;
                                        const double* __restrict__ tmp_col = tmp_tile + j * ld_tmp;
                                        for (int i = 0; i <= j; ++i) {
                                            tile_out[base_row - (j - i) + col_base] += tmp_col[i];
                                        }
                                    }

                                } else {
                                    const int ld_tmp = active_cols;
                                    const int* __restrict__ aind = semi_in.aind.data();
                                    sTiles::core_dsyrk(sTiles::Uplo::Upper, sTiles::Op::Trans,
                                                    active_cols, rows_in, mzone,
                                                    tile_in, rows_in, 0.0, tmp_tile, ld_tmp);

                                    for (int j = 0; j < active_cols; ++j) {
                                        const int col_idx = aind[j];
                                        const std::size_t col_base = static_cast<std::size_t>(diag_cols) * col_idx;
                                        const double* __restrict__ tmp_col = tmp_tile + j * ld_tmp;
                                        for (int i = 0; i <= j; ++i) {
                                            const int band = col_idx - aind[i];
                                            if (band < diag_cols) {
                                                tile_out[base_row - band + col_base] += tmp_col[i];
                                            } else if (std::fabs(tmp_col[i]) > 1e-15) {
                                                std::fprintf(stderr, "sTiles warning: DSYRK bandwidth overflow in tile k=%d: band=%d >= diag_cols=%d, dropped=%.6e\n",
                                                            k, band, diag_cols, tmp_col[i]);
                                            }
                                        }
                                    }
                                }
                            }
                        }
                        break;
                    }

                    case 3: { // DTRSM — banded triangular solve
                        // (k,k) is the diagonal solve tile → index2.
                        SS_WAIT_DP(k, k, index2, 1);

                        const sTiles::SemisparseTileMetaCore& semi_rhs = semisparse_meta[index1];
                        const int active_cols = semi_rhs.sa;
                        if (active_cols > 0) {
                            double* __restrict__ ss_rhs  = chunked_tiles[index1];
                            double* __restrict__ ss_diag = chunked_tiles[index2];
                            const sTiles::SemisparseTileMetaCore& semi_diag = semisparse_meta[index2];
                            const int rows_rhs = tile_meta[index1].height;
                            const int diag_dim = tile_meta[index2].height;
                            const int kd = semi_diag.upper_bw;

                            lapack_int info = LAPACKE_dtbtrs(LAPACK_COL_MAJOR, 'U', 'T', 'N',
                                                            diag_dim, kd, active_cols,
                                                            ss_diag, kd + 1, ss_rhs, rows_rhs);
                            if (info != 0) {
                                std::fprintf(stderr, "sTiles error: LAPACKE_dtbtrs failed with info=%d (tile m=%d, k=%d)\n",
                                            info, m, k);
                                ss_abort(); break;
                            }
                        }
                        // (m,k) is the off-diagonal output tile → index1.
                        ss_set_done_dp(m, k, index1, 1);
                        break;
                    }

                    default:
                        break;
                }

                if (ss_aborted()) break;
            }
            if (_stiles_dump_pt) {
                const double _dump_pt_dt = omp_get_wtime() - _dump_pt_t0;
                std::fprintf(stderr, "[STILES_DUMP/pthreads_expansion_semi] rank=%d  tasks=[%d,%d)  count=%d  dt=%.4fs  routines: c1=%d c2=%d c3=%d c4=%d\n",
                             rank, start, end, end - start, _dump_pt_dt,
                             _dump_pt_routine_count[1], _dump_pt_routine_count[2],
                             _dump_pt_routine_count[3], _dump_pt_routine_count[4]);
            }
            ss_finalize_dp();
        }

        void omp_dpotrf_expansion_semi_parallel_imp4(TiledMatrix* tiledMatrix, omp_dep_tracker_t* dep_tracker, int worldsize) {
            // OMP SPMD mirror of pthreads_dpotrf_expansion_semi_parallel_imp4.
            // Same body, same path_flag dispatch, same prefetch; only the
            // sync layer differs (dep_* atomics vs ss_* volatile-int).
            (void)worldsize; // offsets array was computed for worldsize threads

            const int rank = omp_get_thread_num();
            const int N = tiledMatrix->dim;
            const int tile_size = tiledMatrix->tile_size;
            const int num_tiles_per_dim = (N == 0) ? 0 : (N - 1) / tile_size + 1;

            double** __restrict__ const chunked_tiles = tiledMatrix->chunkedDenseTiles;
            const sTiles::SemisparseTileMetaCore* __restrict__ const semisparse_meta = tiledMatrix->semisparseTileMetaCore;
            const sTiles::TileMetaCore* __restrict__ const tile_meta = tiledMatrix->tileMetaCore;

            const auto &tasks = sTiles::get_chol_tasks(tiledMatrix);
            const auto &offsets = sTiles::get_chol_task_offsets(tiledMatrix);
            const int start = (rank < static_cast<int>(offsets.size())) ? offsets[rank] : 0;
            const int end = (rank + 1 < static_cast<int>(offsets.size())) ? offsets[rank + 1] : static_cast<int>(tasks.size());

            if (rank >= tiledMatrix->num_workspaces) {
                sTiles::Logger::error("[semi_parallel_imp4_omp] rank ", rank, " >= num_workspaces ", tiledMatrix->num_workspaces);
                return;
            }
            double* __restrict__ tmp_tile = tiledMatrix->workspaces[rank]->aligned_tile();
            const double mzone = -1.0;

            constexpr int FUSE_THRESHOLD = 16;

            const int64_t* scatter_index = tiledMatrix->chol_scatter_index->data();
            const int32_t* scatter_packed = tiledMatrix->chol_scatter_packed->data();

            dep_init_dp(tiledMatrix, num_tiles_per_dim, tiledMatrix->numActiveTiles, 0);

            const int ntiles_bounds = tiledMatrix->numActiveTiles;

            // ──────────── STILES_DUMP_TASKS instrumentation ────────────
            // Env-gated stderr dump of per-thread task slice + per-routine counts
            // and per-thread wallclock. Set STILES_DUMP_TASKS=1 to enable.
            const bool _stiles_dump = []() {
                const char* v = std::getenv("STILES_DUMP_TASKS");
                return v && std::atoi(v) != 0;
            }();
            if (_stiles_dump) {
                #pragma omp single nowait
                std::fprintf(stderr, "[STILES_DUMP] total_chol_tasks=%d  worldsize=%d  num_tiles_per_dim=%d  numActiveTiles=%d\n",
                             static_cast<int>(tasks.size()), worldsize, num_tiles_per_dim, tiledMatrix->numActiveTiles);
            }
            int _dump_routine_count[5] = {0,0,0,0,0};
            const double _dump_t0 = _stiles_dump ? omp_get_wtime() : 0.0;

            for (int idx = start; idx < end; ++idx) {
                const std::array<int,7> &t = tasks[idx];
                const int myroutine = t[0];
                const int m = t[1];
                const int k = t[2];
                const int n = t[3];
                const int index1 = t[4];
                const int index2 = t[5];
                const int index3 = t[6];

                if (idx + 1 < end) {
                    const std::array<int,7> &next_t = tasks[idx + 1];
                    const int next_routine = next_t[0];
                    const int next_idx1 = next_t[4];
                    const int next_idx2 = next_t[5];

                    if (next_idx1 >= 0 && next_idx1 < ntiles_bounds && chunked_tiles[next_idx1]) {
                        __builtin_prefetch(chunked_tiles[next_idx1], 0, 2);
                    }
                    if (next_idx2 >= 0 && next_idx2 < ntiles_bounds && chunked_tiles[next_idx2]) {
                        __builtin_prefetch(chunked_tiles[next_idx2], 1, 2);
                    }
                    if (next_routine == 4) {
                        const int next_idx3 = next_t[6];
                        if (next_idx3 >= 0 && next_idx3 < ntiles_bounds && chunked_tiles[next_idx3]) {
                            __builtin_prefetch(chunked_tiles[next_idx3], 1, 2);
                        }
                        const int64_t next_si = static_cast<int64_t>(idx + 1) * 2;
                        __builtin_prefetch(&scatter_index[next_si], 0, 3);
                        const int64_t next_data_off = scatter_index[next_si];
                        if (next_data_off >= 0) {
                            __builtin_prefetch(scatter_packed + next_data_off, 0, 3);
                        }
                    }
                    __builtin_prefetch(&semisparse_meta[next_idx1], 0, 3);
                    __builtin_prefetch(&semisparse_meta[next_idx2], 0, 3);
                    if (next_idx1 >= 0 && next_idx1 < ntiles_bounds) {
                        const int* aind_ptr = semisparse_meta[next_idx1].aind.data();
                        if (aind_ptr) __builtin_prefetch(aind_ptr, 0, 2);
                    }
                }

                switch (myroutine) {

                    case 4: { // DGEMM — C(k,m) -= A(n,k)^T * B(n,m)
                        // (k,n) is tile A → index1; (m,n) is tile B → index2.
                        dep_wait_for_dp(k, n, index1, 1);
                        dep_wait_for_dp(m, n, index2, 1);

                        double* __restrict__ chunk_out = chunked_tiles[index3];
                        const int rows_out = tile_meta[index3].height;

                        double* __restrict__ chunk_a = chunked_tiles[index1];
                        double* __restrict__ chunk_b = chunked_tiles[index2];

                        const sTiles::SemisparseTileMetaCore& semi_a = semisparse_meta[index1];
                        const sTiles::SemisparseTileMetaCore& semi_b = semisparse_meta[index2];

                        const int cols_a = semi_a.sa;
                        const int cols_b = semi_b.sa;
                        const int rows_a = tile_meta[index1].height;

                        const int si_base = idx * 2;
                        const int64_t data_off  = scatter_index[si_base];
                        const int path_flag = static_cast<int>(scatter_index[si_base + 1]);

                        if (path_flag == 0) {
                            const int a_start = semi_a.fa;
                            const int b_start = semi_b.fa;
                            cblas_dgemm(CblasColMajor, CblasTrans, CblasNoTrans,
                                        cols_a, cols_b, rows_a, mzone,
                                        chunk_a, rows_a, chunk_b, rows_a,
                                        1.0, chunk_out + a_start + static_cast<std::size_t>(b_start) * rows_out, rows_out);

                        } else if (path_flag == 1) {
                            const int a_start = semi_a.fa;
                            const int32_t* slots = scatter_packed + data_off;
                            const int cols_a_pair = cols_a & ~1;
                            for (int j = 0; j < cols_b; ++j) {
                                const int slot = slots[j];
                                if (slot < 0) continue;
                                double* __restrict__ out_col = chunk_out + static_cast<std::size_t>(slot) * rows_out + a_start;
                                const double* __restrict__ col_b_j = chunk_b + static_cast<std::size_t>(j) * rows_a;
                                int i = 0;
                                for (; i < cols_a_pair; i += 2) {
                                    const double* __restrict__ col_a_i0 = chunk_a + static_cast<std::size_t>(i)     * rows_a;
                                    const double* __restrict__ col_a_i1 = chunk_a + static_cast<std::size_t>(i + 1) * rows_a;
                                    double dot0 = 0.0, dot1 = 0.0;
                                    #pragma omp simd reduction(+:dot0,dot1)
                                    for (int r = 0; r < rows_a; ++r) {
                                        const double bv = col_b_j[r];
                                        dot0 += col_a_i0[r] * bv;
                                        dot1 += col_a_i1[r] * bv;
                                    }
                                    out_col[i]     -= dot0;
                                    out_col[i + 1] -= dot1;
                                }
                                if (i < cols_a) {
                                    const double* __restrict__ col_a_i = chunk_a + static_cast<std::size_t>(i) * rows_a;
                                    double dot = 0.0;
                                    #pragma omp simd reduction(+:dot)
                                    for (int r = 0; r < rows_a; ++r) dot += col_a_i[r] * col_b_j[r];
                                    out_col[i] -= dot;
                                }
                            }

                        } else if (path_flag == 2) {
                            const int* __restrict__ aind_a = semi_a.aind.data();
                            const int32_t* slots = scatter_packed + data_off;
                            const int cols_a_pair = cols_a & ~1;
                            for (int j = 0; j < cols_b; ++j) {
                                const int slot = slots[j];
                                if (slot < 0) continue;
                                double* __restrict__ out_col = chunk_out + static_cast<std::size_t>(slot) * rows_out;
                                const double* __restrict__ col_b_j = chunk_b + static_cast<std::size_t>(j) * rows_a;
                                int i = 0;
                                for (; i < cols_a_pair; i += 2) {
                                    const double* __restrict__ col_a_i0 = chunk_a + static_cast<std::size_t>(i)     * rows_a;
                                    const double* __restrict__ col_a_i1 = chunk_a + static_cast<std::size_t>(i + 1) * rows_a;
                                    double dot0 = 0.0, dot1 = 0.0;
                                    #pragma omp simd reduction(+:dot0,dot1)
                                    for (int r = 0; r < rows_a; ++r) {
                                        const double bv = col_b_j[r];
                                        dot0 += col_a_i0[r] * bv;
                                        dot1 += col_a_i1[r] * bv;
                                    }
                                    out_col[aind_a[i]]     -= dot0;
                                    out_col[aind_a[i + 1]] -= dot1;
                                }
                                if (i < cols_a) {
                                    const double* __restrict__ col_a_i = chunk_a + static_cast<std::size_t>(i) * rows_a;
                                    double dot = 0.0;
                                    #pragma omp simd reduction(+:dot)
                                    for (int r = 0; r < rows_a; ++r) dot += col_a_i[r] * col_b_j[r];
                                    out_col[aind_a[i]] -= dot;
                                }
                            }

                        } else if (path_flag == 3) {
                            const int ld_tmp = cols_a;
                            const int a_start = semi_a.fa;
                            const int32_t* slots = scatter_packed + data_off;
                            sTiles::core_dgemm(sTiles::Op::Trans, sTiles::Op::NoTrans,
                                            cols_a, cols_b, rows_a,
                                            mzone, chunk_a, rows_a, chunk_b, rows_a,
                                            0.0, tmp_tile, ld_tmp);
                            for (int j = 0; j < cols_b; ++j) {
                                const int slot = slots[j];
                                if (slot < 0) continue;
                                double* __restrict__ out_col = chunk_out + static_cast<std::size_t>(slot) * rows_out + a_start;
                                const double* __restrict__ tmp_col = tmp_tile + j * ld_tmp;
                                #pragma omp simd
                                for (int i = 0; i < cols_a; ++i) out_col[i] += tmp_col[i];
                            }

                        } else if (path_flag == 4) {
                            const int ld_tmp = cols_a;
                            const int* __restrict__ aind_a = semi_a.aind.data();
                            const int32_t* slots = scatter_packed + data_off;
                            sTiles::core_dgemm(sTiles::Op::Trans, sTiles::Op::NoTrans,
                                            cols_a, cols_b, rows_a,
                                            mzone, chunk_a, rows_a, chunk_b, rows_a,
                                            0.0, tmp_tile, ld_tmp);
                            for (int j = 0; j < cols_b; ++j) {
                                const int slot = slots[j];
                                if (slot < 0) continue;
                                double* __restrict__ out_col = chunk_out + static_cast<std::size_t>(slot) * rows_out;
                                const double* __restrict__ tmp_col = tmp_tile + j * ld_tmp;
                                int i = 0;
                                for (; i + 3 < cols_a; i += 4) {
                                    out_col[aind_a[i]]     += tmp_col[i];
                                    out_col[aind_a[i + 1]] += tmp_col[i + 1];
                                    out_col[aind_a[i + 2]] += tmp_col[i + 2];
                                    out_col[aind_a[i + 3]] += tmp_col[i + 3];
                                }
                                for (; i < cols_a; ++i) out_col[aind_a[i]] += tmp_col[i];
                            }
                        }
                        break;
                    }

                    case 1: { // DPOTRF — banded Cholesky on diagonal tile
                        double* __restrict__ tile_out = chunked_tiles[index1];
                        const sTiles::SemisparseTileMetaCore& semi = semisparse_meta[index1];
                        const sTiles::TileMetaCore& meta = tile_meta[index1];
                        sTiles::StatusCode ssstatus = sTiles::core_dpotrf_upper_banded(meta.height, semi.upper_bw, tile_out);
                        if (ssstatus != sTiles::StatusCode::Success) {
                            std::fprintf(stderr, "sTiles error: matrix is not positive definite (banded tile k=%d).\n", k);
                            dep_abort_all(); break;
                        }
                        // (k,k) → index1 in this case.
                        dep_set_done_dp(k, k, index1, 1);
                        break;
                    }

                    case 2: { // DSYRK — symmetric rank-k update into banded diagonal
                        // (k,n) → index1.
                        dep_wait_for_dp(k, n, index1, 1);

                        double* __restrict__ tile_in = chunked_tiles[index1];
                        double* __restrict__ tile_out = chunked_tiles[index2];

                        if (tile_in && tile_out) {
                            const sTiles::SemisparseTileMetaCore& semi_in = semisparse_meta[index1];
                            const int active_cols = semi_in.sa;

                            if (active_cols > 0) {
                                const sTiles::SemisparseTileMetaCore& semi_out = semisparse_meta[index2];
                                const int diag_cols = semi_out.upper_bw + 1;
                                const int rows_in = (tile_meta[index1].height > 0) ? tile_meta[index1].height : tile_size;
                                const int base_row = diag_cols - 1;

                                const bool aind_contig = semi_in.is_contiguous;

                                if (active_cols <= FUSE_THRESHOLD && aind_contig && active_cols <= diag_cols) {
                                    const int aind_start = semi_in.fa;
                                    for (int j = 0; j < active_cols; ++j) {
                                        const int col_idx = aind_start + j;
                                        const std::size_t col_base = static_cast<std::size_t>(diag_cols) * col_idx;
                                        const double* __restrict__ col_j = tile_in + static_cast<std::size_t>(j) * rows_in;
                                        for (int i = 0; i <= j; ++i) {
                                            const double* __restrict__ col_i = tile_in + static_cast<std::size_t>(i) * rows_in;
                                            double dot = 0.0;
                                            #pragma omp simd reduction(+:dot)
                                            for (int r = 0; r < rows_in; ++r) {
                                                dot += col_i[r] * col_j[r];
                                            }
                                            tile_out[base_row - (j - i) + col_base] -= dot;
                                        }
                                    }

                                } else if (active_cols <= FUSE_THRESHOLD) {
                                    const int* __restrict__ aind = semi_in.aind.data();
                                    for (int j = 0; j < active_cols; ++j) {
                                        const int col_idx = aind[j];
                                        const std::size_t col_base = static_cast<std::size_t>(diag_cols) * col_idx;
                                        const double* __restrict__ col_j = tile_in + static_cast<std::size_t>(j) * rows_in;
                                        for (int i = 0; i <= j; ++i) {
                                            const int band = col_idx - aind[i];
                                            if (band < diag_cols) {
                                                const double* __restrict__ col_i = tile_in + static_cast<std::size_t>(i) * rows_in;
                                                double dot = 0.0;
                                                #pragma omp simd reduction(+:dot)
                                                for (int r = 0; r < rows_in; ++r) {
                                                    dot += col_i[r] * col_j[r];
                                                }
                                                tile_out[base_row - band + col_base] -= dot;
                                            }
                                        }
                                    }

                                } else if (aind_contig && active_cols <= diag_cols) {
                                    const int ld_tmp = active_cols;
                                    sTiles::core_dsyrk(sTiles::Uplo::Upper, sTiles::Op::Trans,
                                                    active_cols, rows_in, mzone,
                                                    tile_in, rows_in, 0.0, tmp_tile, ld_tmp);

                                    const int aind_start = semi_in.fa;
                                    for (int j = 0; j < active_cols; ++j) {
                                        const int col_idx = aind_start + j;
                                        const std::size_t col_base = static_cast<std::size_t>(diag_cols) * col_idx;
                                        const double* __restrict__ tmp_col = tmp_tile + j * ld_tmp;
                                        for (int i = 0; i <= j; ++i) {
                                            tile_out[base_row - (j - i) + col_base] += tmp_col[i];
                                        }
                                    }

                                } else {
                                    const int ld_tmp = active_cols;
                                    const int* __restrict__ aind = semi_in.aind.data();
                                    sTiles::core_dsyrk(sTiles::Uplo::Upper, sTiles::Op::Trans,
                                                    active_cols, rows_in, mzone,
                                                    tile_in, rows_in, 0.0, tmp_tile, ld_tmp);

                                    for (int j = 0; j < active_cols; ++j) {
                                        const int col_idx = aind[j];
                                        const std::size_t col_base = static_cast<std::size_t>(diag_cols) * col_idx;
                                        const double* __restrict__ tmp_col = tmp_tile + j * ld_tmp;
                                        for (int i = 0; i <= j; ++i) {
                                            const int band = col_idx - aind[i];
                                            if (band < diag_cols) {
                                                tile_out[base_row - band + col_base] += tmp_col[i];
                                            } else if (std::fabs(tmp_col[i]) > 1e-15) {
                                                std::fprintf(stderr, "sTiles warning: DSYRK bandwidth overflow in tile k=%d: band=%d >= diag_cols=%d, dropped=%.6e\n",
                                                            k, band, diag_cols, tmp_col[i]);
                                            }
                                        }
                                    }
                                }
                            }
                        }
                        break;
                    }

                    case 3: { // DTRSM — banded triangular solve
                        // (k,k) → index2 (the diagonal solve tile).
                        dep_wait_for_dp(k, k, index2, 1);

                        const sTiles::SemisparseTileMetaCore& semi_rhs = semisparse_meta[index1];
                        const int active_cols = semi_rhs.sa;
                        if (active_cols > 0) {
                            double* __restrict__ ss_rhs  = chunked_tiles[index1];
                            double* __restrict__ ss_diag = chunked_tiles[index2];
                            const sTiles::SemisparseTileMetaCore& semi_diag = semisparse_meta[index2];
                            const int rows_rhs = tile_meta[index1].height;
                            const int diag_dim = tile_meta[index2].height;
                            const int kd = semi_diag.upper_bw;

                            lapack_int info = LAPACKE_dtbtrs(LAPACK_COL_MAJOR, 'U', 'T', 'N',
                                                            diag_dim, kd, active_cols,
                                                            ss_diag, kd + 1, ss_rhs, rows_rhs);
                            if (info != 0) {
                                std::fprintf(stderr, "sTiles error: LAPACKE_dtbtrs failed with info=%d (tile m=%d, k=%d)\n",
                                            info, m, k);
                                dep_abort_all(); break;
                            }
                        }
                        // (m,k) → index1.
                        dep_set_done_dp(m, k, index1, 1);
                        break;
                    }

                    default:
                        break;
                }

                if (_stiles_dump && myroutine >= 0 && myroutine < 5) {
                    _dump_routine_count[myroutine]++;
                }
                if (dep_is_aborted()) break;
            }
            if (_stiles_dump) {
                const double _dump_dt = omp_get_wtime() - _dump_t0;
                #pragma omp critical
                std::fprintf(stderr, "[STILES_DUMP] rank=%d  tasks=[%d,%d)  count=%d  dt=%.4fs  routines: c1=%d c2=%d c3=%d c4=%d\n",
                             rank, start, end, end - start, _dump_dt,
                             _dump_routine_count[1], _dump_routine_count[2],
                             _dump_routine_count[3], _dump_routine_count[4]);
            }
            dep_finalize_dp();
        }

        ////////////////////////////////////////////////////////////////////////////////
        ////////////////////////////////////////////////////////////////////////////////

        ////////////////////////////////////////////////////////////////////////////////

        //------------------> Treeees 
        
        ////////////////////////////////////////////////////////////////////////////////

        // Dense tree-reduction executor (tile mode 0, red_tree_separator_level > 0).
        //
        // Same data layout as pthreads_dpotrf_expansion_dense_parallel (operates on
        // tiledMatrix->denseTiles) but handles routines 5–10 emitted by
        // chol_reduction_variant for separator-corner tiles:
        //
        //   1–4  : standard DPOTRF / DSYRK / DTRSM / DGEMM (Region A + non-tree fallbacks in Region B)
        //   5    : tree DSYRK — accumulate partial diag update into trees[t]->nodes[rank].x
        //   6    : set dependency flag for diag reduce (token = index3)
        //   7    : DGEADD-reduce — rank 0 waits on every rank's flag, sums scratches into A(k,k)
        //   8    : tree DGEMM — accumulate partial off-diag update into trees[t]->nodes[rank].x
        //   9    : set dependency flag for off-diag reduce (token = 165715)
        //   10   : DGEADD-reduce — rank 0 sums scratches into A(k,m)
        //
        // The collector guarantees cases 5/8 are emitted only when trees[t] != nullptr,
        // so we don't null-check tree pointers inside the inner loop.
        void pthreads_dpotrf_reduction_dense(TiledMatrix *tiledMatrix, stiles_context_t *stile) {

            const int rank = STILES_RANK;
            const int N = tiledMatrix->dim;
            const int tile_size = tiledMatrix->tile_size;
            const int num_tiles_per_dim = sTiles_layout_num_tiles(N, tile_size);
            #define BLKADD_CT(k) sTiles_layout_tile_dim((k), N, tile_size, num_tiles_per_dim)

            const auto &tasks = sTiles::get_chol_tasks(tiledMatrix);
            const auto &offsets = sTiles::get_chol_task_offsets(tiledMatrix);
            const int start = (rank < static_cast<int>(offsets.size())) ? offsets[rank] : 0;
            const int end = (rank + 1 < static_cast<int>(offsets.size())) ? offsets[rank + 1] : static_cast<int>(tasks.size());

            ss_init_dp(tiledMatrix, num_tiles_per_dim, tiledMatrix->numActiveTiles, 0);

            for (int idx = start; idx < end; ++idx) {

                const std::array<int,7> &t = tasks[idx];
                const int myroutine = t[0];
                const int m = t[1];
                const int k = t[2];
                const int n = t[3];
                const int index1 = t[4];
                const int index2 = t[5];
                const int index3 = t[6];

                const int tempkn = (k == (num_tiles_per_dim - 1)) ? (N - k * tile_size) : tile_size;
                const int tempmn = (m == (num_tiles_per_dim - 1)) ? (N - m * tile_size) : tile_size;
                const int ldak = BLKADD_CT(k);
                const int ldan = BLKADD_CT(n);

                const double zone = 1.0;
                const double mzone = -1.0;

                switch (myroutine) {
                    case 1: { // DPOTRF
                        double *tile_out = tiledMatrix->denseTiles[index1];
                        sTiles::StatusCode status = sTiles::core_dpotrf(sTiles::Uplo::Upper, tempkn, tile_out, ldak);
                        if (status != sTiles::StatusCode::Success) {
                            std::fprintf(stderr, "sTiles error: matrix is not positive definite (tile k=%d).\n", k);
                            ss_abort(); break;
                        }
                        // (k,k) → index1
                        ss_set_done_dp(k, k, index1, 1);
                        break;
                    }
                    case 2: { // DSYRK
                        // (k,n) → index1
                        SS_COND_WAIT_DP(k, n, index1, 1);
                        double *tile_in = tiledMatrix->denseTiles[index1];
                        double *tile_out = tiledMatrix->denseTiles[index2];
                        if (tile_in && tile_out) sTiles::core_dsyrk(sTiles::Uplo::Upper, sTiles::Op::Trans, tempkn, tile_size, mzone, tile_in, ldan, zone, tile_out, ldak);
                        break;
                    }
                    case 3: { // DTRSM
                        // (k,k) → index2
                        SS_COND_WAIT_DP(k, k, index2, 1);
                        double *tile_rhs = tiledMatrix->denseTiles[index2];
                        double *tile_out = tiledMatrix->denseTiles[index1];
                        if (tile_rhs && tile_out) sTiles::core_dtrsm(sTiles::Side::Left, sTiles::Uplo::Upper, sTiles::Op::Trans, sTiles::Diag::NonUnit, tile_size, tempmn, zone, tile_rhs, ldak, tile_out, ldak);
                        // (m,k) → index1
                        ss_set_done_dp(m, k, index1, 1);
                        break;
                    }
                    case 4: { // DGEMM
                        // (k,n) → index1; (m,n) → index2
                        SS_COND_WAIT_DP(k, n, index1, 1);
                        SS_COND_WAIT_DP(m, n, index2, 1);
                        double *tile_a = tiledMatrix->denseTiles[index1];
                        double *tile_b = tiledMatrix->denseTiles[index2];
                        double *tile_out = tiledMatrix->denseTiles[index3];
                        if (tile_out && tile_a && tile_b) sTiles::core_dgemm(sTiles::Op::Trans, sTiles::Op::NoTrans, tile_size, tempmn, tile_size, mzone, tile_a, ldan, tile_b, ldan, zone, tile_out, ldak);
                        break;
                    }
                    case 5: { // Tree DSYRK — accumulate partial sum of A^T A into private scratch (positive).
                        // First-use beta = 0 (overwrites stale data, no separate memset); subsequent = 1.
                        // (k,n) → index1
                        SS_COND_WAIT_DP(k, n, index1, 1);
                        double *tile_in  = tiledMatrix->denseTiles[index1];
                        auto &node5 = tiledMatrix->trees[index2]->nodes[rank];
                        double *tile_out = node5.x;
                        if (tile_in) {
                            const double beta = node5.dirty ? zone : 0.0;
                            sTiles::core_dsyrk(sTiles::Uplo::Upper, sTiles::Op::Trans, tempkn, tile_size, zone, tile_in, ldan, beta, tile_out, ldak);
                            node5.dirty = 1;
                        }
                        break;
                    }
                    case 6: { // Set dependency flag — this rank's diag tree slice is done
                        tiledMatrix->trees[index2]->dependency[rank] = index3;
                        break;
                    }
                    case 7: { // DGEADD-reduce — subtract sum of scratches from diag tile (skip ranks with !dirty)
                        const sTiles::TileMetaCore* meta_out_ptr = tiledMatrix->tileMetaCore ? &tiledMatrix->tileMetaCore[index2] : nullptr;
                        const int tile_height = (meta_out_ptr && meta_out_ptr->height > 0) ? meta_out_ptr->height : tile_size;
                        const int tile_width  = (meta_out_ptr && meta_out_ptr->width  > 0) ? meta_out_ptr->width  : tile_size;
                        double *tile_out = tiledMatrix->denseTiles[index2];
                        for (int rank_idx = 0; rank_idx < STILES_SIZE; ++rank_idx) {
                            if (rank_idx > 0) ss_cond_wait_tree_e_s_t_y_l_e(rank_idx, index3, tiledMatrix->trees[index1]->dependency);
                            if (tiledMatrix->trees[index1]->nodes[rank_idx].dirty) {
                                double *tree_tile = tiledMatrix->trees[index1]->nodes[rank_idx].x;
                                sTiles::core_dgeadd(sTiles::Op::NoTrans, tile_height, tile_width, mzone, tree_tile, tile_height, zone, tile_out, tile_height);
                                tiledMatrix->trees[index1]->nodes[rank_idx].dirty = 0;
                            }
                            tiledMatrix->trees[index1]->dependency[rank_idx] = 0;
                        }
                        break;
                    }
                    case 8: { // Tree DGEMM — accumulate partial A^T B into private scratch (positive).
                        // First-use beta = 0; subsequent = 1.
                        // (k,n) → index1; (m,n) → index2
                        SS_COND_WAIT_DP(k, n, index1, 1);
                        SS_COND_WAIT_DP(m, n, index2, 1);
                        double *tile_a = tiledMatrix->denseTiles[index1];
                        double *tile_b = tiledMatrix->denseTiles[index2];
                        auto &node8 = tiledMatrix->trees[index3]->nodes[rank];
                        double *tile_out = node8.x;
                        if (tile_a && tile_b) {
                            const double beta = node8.dirty ? zone : 0.0;
                            sTiles::core_dgemm(sTiles::Op::Trans, sTiles::Op::NoTrans, tile_size, tempmn, tile_size, zone, tile_a, ldan, tile_b, ldan, beta, tile_out, ldak);
                            node8.dirty = 1;
                        }
                        break;
                    }
                    case 9: { // Set dependency flag — this rank's off-diag tree slice is done
                        tiledMatrix->trees[index2]->dependency[rank] = 165715;
                        break;
                    }
                    case 10: { // DGEADD-reduce — subtract sum of scratches from off-diag tile (skip ranks with !dirty)
                        const sTiles::TileMetaCore* meta_out_ptr2 = tiledMatrix->tileMetaCore ? &tiledMatrix->tileMetaCore[index3] : nullptr;
                        const int tile_height2 = (meta_out_ptr2 && meta_out_ptr2->height > 0) ? meta_out_ptr2->height : tile_size;
                        const int tile_width2  = (meta_out_ptr2 && meta_out_ptr2->width  > 0) ? meta_out_ptr2->width  : tile_size;
                        double *tile_out2 = tiledMatrix->denseTiles[index3];
                        for (int rank_idx = 0; rank_idx < STILES_SIZE; ++rank_idx) {
                            if (rank_idx > 0) ss_cond_wait_tree_e_s_t_y_l_e(rank_idx, 165715, tiledMatrix->trees[index1]->dependency);
                            if (tiledMatrix->trees[index1]->nodes[rank_idx].dirty) {
                                double *tree_tile = tiledMatrix->trees[index1]->nodes[rank_idx].x;
                                sTiles::core_dgeadd(sTiles::Op::NoTrans, tile_height2, tile_width2, mzone, tree_tile, tile_height2, zone, tile_out2, tile_height2);
                                tiledMatrix->trees[index1]->nodes[rank_idx].dirty = 0;
                            }
                            tiledMatrix->trees[index1]->dependency[rank_idx] = 0;
                        }
                        break;
                    }
                    default:
                        break;
                }
                if (ss_aborted()) break;
            }
            ss_finalize_dp();

            #undef BLKADD_CT
        }

        // OMP mirror of pthreads_dpotrf_reduction_dense. Same algorithm, same
        // routine 1–10 handling; only the synchronization layer differs:
        //   ss_init/ss_cond_wait/ss_cond_set/ss_aborted/ss_finalize → dep_init/dep_wait_for/dep_set_done/dep_is_aborted/dep_finalize
        //   ss_cond_wait_tree_e_s_t_y_l_e                            → dep_wait_for_tree
        //   stile->ss_abort = 1                                      → dep_tracker->abort_flag.store(true, ...)
        //   STILES_RANK / STILES_SIZE                                → omp_get_thread_num() / worldsize
        void omp_dpotrf_reduction_dense(TiledMatrix *tiledMatrix, omp_dep_tracker_t* dep_tracker, int worldsize) {

            const int rank = omp_get_thread_num();
            const int N = tiledMatrix->dim;
            const int tile_size = tiledMatrix->tile_size;
            const int num_tiles_per_dim = sTiles_layout_num_tiles(N, tile_size);
            #define BLKADD_CT(k) sTiles_layout_tile_dim((k), N, tile_size, num_tiles_per_dim)

            const auto &tasks = sTiles::get_chol_tasks(tiledMatrix);
            const auto &offsets = sTiles::get_chol_task_offsets(tiledMatrix);
            const int start = (rank < static_cast<int>(offsets.size())) ? offsets[rank] : 0;
            const int end = (rank + 1 < static_cast<int>(offsets.size())) ? offsets[rank + 1] : static_cast<int>(tasks.size());

            dep_init_dp(tiledMatrix, num_tiles_per_dim, tiledMatrix->numActiveTiles, 0);

            for (int idx = start; idx < end; ++idx) {

                const std::array<int,7> &t = tasks[idx];
                const int myroutine = t[0];
                const int m = t[1];
                const int k = t[2];
                const int n = t[3];
                const int index1 = t[4];
                const int index2 = t[5];
                const int index3 = t[6];

                const int tempkn = (k == (num_tiles_per_dim - 1)) ? (N - k * tile_size) : tile_size;
                const int tempmn = (m == (num_tiles_per_dim - 1)) ? (N - m * tile_size) : tile_size;
                const int ldak = BLKADD_CT(k);
                const int ldan = BLKADD_CT(n);

                const double zone = 1.0;
                const double mzone = -1.0;

                switch (myroutine) {
                    case 1: { // DPOTRF
                        double *tile_out = tiledMatrix->denseTiles[index1];
                        sTiles::StatusCode status = sTiles::core_dpotrf(sTiles::Uplo::Upper, tempkn, tile_out, ldak);
                        if (status != sTiles::StatusCode::Success) {
                            std::fprintf(stderr, "sTiles error: matrix is not positive definite (tile k=%d).\n", k);
                            dep_abort_all(); break;
                        }
                        // (k,k) → index1
                        dep_set_done_dp(k, k, index1, 1);
                        break;
                    }
                    case 2: { // DSYRK
                        // (k,n) → index1
                        dep_wait_for_dp(k, n, index1, 1);
                        double *tile_in = tiledMatrix->denseTiles[index1];
                        double *tile_out = tiledMatrix->denseTiles[index2];
                        if (tile_in && tile_out) sTiles::core_dsyrk(sTiles::Uplo::Upper, sTiles::Op::Trans, tempkn, tile_size, mzone, tile_in, ldan, zone, tile_out, ldak);
                        break;
                    }
                    case 3: { // DTRSM
                        // (k,k) → index2
                        dep_wait_for_dp(k, k, index2, 1);
                        double *tile_rhs = tiledMatrix->denseTiles[index2];
                        double *tile_out = tiledMatrix->denseTiles[index1];
                        if (tile_rhs && tile_out) sTiles::core_dtrsm(sTiles::Side::Left, sTiles::Uplo::Upper, sTiles::Op::Trans, sTiles::Diag::NonUnit, tile_size, tempmn, zone, tile_rhs, ldak, tile_out, ldak);
                        // (m,k) → index1
                        dep_set_done_dp(m, k, index1, 1);
                        break;
                    }
                    case 4: { // DGEMM
                        // (k,n) → index1; (m,n) → index2
                        dep_wait_for_dp(k, n, index1, 1);
                        dep_wait_for_dp(m, n, index2, 1);
                        double *tile_a = tiledMatrix->denseTiles[index1];
                        double *tile_b = tiledMatrix->denseTiles[index2];
                        double *tile_out = tiledMatrix->denseTiles[index3];
                        if (tile_out && tile_a && tile_b) sTiles::core_dgemm(sTiles::Op::Trans, sTiles::Op::NoTrans, tile_size, tempmn, tile_size, mzone, tile_a, ldan, tile_b, ldan, zone, tile_out, ldak);
                        break;
                    }
                    case 5: { // Tree DSYRK — accumulate partial sum of A^T A into private scratch.
                        // First-use beta = 0 (overwrites stale data); subsequent = 1.
                        // (k,n) → index1
                        dep_wait_for_dp(k, n, index1, 1);
                        double *tile_in  = tiledMatrix->denseTiles[index1];
                        auto &node5 = tiledMatrix->trees[index2]->nodes[rank];
                        double *tile_out = node5.x;
                        if (tile_in) {
                            const double beta = node5.dirty ? zone : 0.0;
                            sTiles::core_dsyrk(sTiles::Uplo::Upper, sTiles::Op::Trans, tempkn, tile_size, zone, tile_in, ldan, beta, tile_out, ldak);
                            node5.dirty = 1;
                        }
                        break;
                    }
                    case 6: { // Set dependency flag — this rank's diag tree slice is done
                        tiledMatrix->trees[index2]->dependency[rank] = index3;
                        break;
                    }
                    case 7: { // DGEADD-reduce — skip ranks with !dirty (no contributions)
                        const sTiles::TileMetaCore* meta_out_ptr = tiledMatrix->tileMetaCore ? &tiledMatrix->tileMetaCore[index2] : nullptr;
                        const int tile_height = (meta_out_ptr && meta_out_ptr->height > 0) ? meta_out_ptr->height : tile_size;
                        const int tile_width  = (meta_out_ptr && meta_out_ptr->width  > 0) ? meta_out_ptr->width  : tile_size;
                        double *tile_out = tiledMatrix->denseTiles[index2];
                        for (int rank_idx = 0; rank_idx < worldsize; ++rank_idx) {
                            if (rank_idx > 0) dep_wait_for_tree(rank_idx, index3, tiledMatrix->trees[index1]->dependency);
                            if (tiledMatrix->trees[index1]->nodes[rank_idx].dirty) {
                                double *tree_tile = tiledMatrix->trees[index1]->nodes[rank_idx].x;
                                sTiles::core_dgeadd(sTiles::Op::NoTrans, tile_height, tile_width, mzone, tree_tile, tile_height, zone, tile_out, tile_height);
                                tiledMatrix->trees[index1]->nodes[rank_idx].dirty = 0;
                            }
                            tiledMatrix->trees[index1]->dependency[rank_idx] = 0;
                        }
                        break;
                    }
                    case 8: { // Tree DGEMM — accumulate partial A^T B into private scratch.
                        // First-use beta = 0; subsequent = 1.
                        // (k,n) → index1; (m,n) → index2
                        dep_wait_for_dp(k, n, index1, 1);
                        dep_wait_for_dp(m, n, index2, 1);
                        double *tile_a = tiledMatrix->denseTiles[index1];
                        double *tile_b = tiledMatrix->denseTiles[index2];
                        auto &node8 = tiledMatrix->trees[index3]->nodes[rank];
                        double *tile_out = node8.x;
                        if (tile_a && tile_b) {
                            const double beta = node8.dirty ? zone : 0.0;
                            sTiles::core_dgemm(sTiles::Op::Trans, sTiles::Op::NoTrans, tile_size, tempmn, tile_size, zone, tile_a, ldan, tile_b, ldan, beta, tile_out, ldak);
                            node8.dirty = 1;
                        }
                        break;
                    }
                    case 9: { // Set dependency flag — this rank's off-diag tree slice is done
                        tiledMatrix->trees[index2]->dependency[rank] = 165715;
                        break;
                    }
                    case 10: { // DGEADD-reduce — skip ranks with !dirty
                        const sTiles::TileMetaCore* meta_out_ptr2 = tiledMatrix->tileMetaCore ? &tiledMatrix->tileMetaCore[index3] : nullptr;
                        const int tile_height2 = (meta_out_ptr2 && meta_out_ptr2->height > 0) ? meta_out_ptr2->height : tile_size;
                        const int tile_width2  = (meta_out_ptr2 && meta_out_ptr2->width  > 0) ? meta_out_ptr2->width  : tile_size;
                        double *tile_out2 = tiledMatrix->denseTiles[index3];
                        for (int rank_idx = 0; rank_idx < worldsize; ++rank_idx) {
                            if (rank_idx > 0) dep_wait_for_tree(rank_idx, 165715, tiledMatrix->trees[index1]->dependency);
                            if (tiledMatrix->trees[index1]->nodes[rank_idx].dirty) {
                                double *tree_tile = tiledMatrix->trees[index1]->nodes[rank_idx].x;
                                sTiles::core_dgeadd(sTiles::Op::NoTrans, tile_height2, tile_width2, mzone, tree_tile, tile_height2, zone, tile_out2, tile_height2);
                                tiledMatrix->trees[index1]->nodes[rank_idx].dirty = 0;
                            }
                            tiledMatrix->trees[index1]->dependency[rank_idx] = 0;
                        }
                        break;
                    }
                    default:
                        break;
                }
                if (dep_is_aborted()) break;
            }
            dep_finalize_dp();

            #undef BLKADD_CT
        }

        // Semisparse tree-reduction executor (tile mode 1, red_tree_separator_level > 0).
        //
        // Cases 1–4: standard semisparse routines (banded DPOTRF, banded DSYRK,
        //            banded DTRSM via LAPACKE_dtbtrs, semisparse DGEMM with
        //            path_flag dispatch) — copied from _expansion_semi_parallel_imp4.
        //
        // Cases 5, 8: tree DSYRK / tree DGEMM. Inputs are semisparse
        //            (column-packed with semi.aind / fa); output is the dense
        //            tile_size × tile_size scratch tile in trees[t]->nodes[rank].x.
        //            We compute the contracted product (cols × cols for DSYRK,
        //            cols_a × cols_b for DGEMM) into the per-rank workspace
        //            tmp_tile, then scatter into the dense scratch at positions
        //            indexed by the semisparse columns' aind.
        //
        // Cases 7, 10: cross-rank reduce. Each rank's scratch is a dense
        //            tile_size × tile_size partial sum. We fold rank-by-rank
        //            into the destination tile:
        //              - Case 7 (diagonal): fold into upper-banded storage
        //                (diag_cols = upper_bw+1 rows, base_row = upper_bw).
        //              - Case 10 (off-diagonal): scatter into the destination's
        //                semisparse column layout (column j of packed storage
        //                corresponds to scratch column semi_out.aind[j] or fa+j).
        //
        // The collector guarantees cases 5/8 are emitted only when trees[t] != nullptr.
        void pthreads_dpotrf_reduction_semi(TiledMatrix *tiledMatrix, stiles_context_t *stile) {

            const int rank = STILES_RANK;
            const int N = tiledMatrix->dim;
            const int tile_size = tiledMatrix->tile_size;
            const int num_tiles_per_dim = (N == 0) ? 0 : (N - 1) / tile_size + 1;

            double** __restrict__ const chunked_tiles = tiledMatrix->chunkedDenseTiles;
            const sTiles::SemisparseTileMetaCore* __restrict__ const semisparse_meta = tiledMatrix->semisparseTileMetaCore;
            const sTiles::TileMetaCore* __restrict__ const tile_meta = tiledMatrix->tileMetaCore;

            const auto &tasks = sTiles::get_chol_tasks(tiledMatrix);
            const auto &offsets = sTiles::get_chol_task_offsets(tiledMatrix);
            const int start = (rank < static_cast<int>(offsets.size())) ? offsets[rank] : 0;
            const int end = (rank + 1 < static_cast<int>(offsets.size())) ? offsets[rank + 1] : static_cast<int>(tasks.size());

            if (rank >= tiledMatrix->num_workspaces) {
                sTiles::Logger::error("[reduction_semi] rank ", rank, " >= num_workspaces ", tiledMatrix->num_workspaces);
                return;
            }
            double* __restrict__ tmp_tile = tiledMatrix->workspaces[rank]->aligned_tile();
            const double zone = 1.0;
            const double mzone = -1.0;

            const int64_t* scatter_index = tiledMatrix->chol_scatter_index->data();
            const int32_t* scatter_packed = tiledMatrix->chol_scatter_packed->data();

            ss_init_dp(tiledMatrix, num_tiles_per_dim, tiledMatrix->numActiveTiles, 0);

            const bool _stiles_dump_ptr = []() {
                const char* v = std::getenv("STILES_DUMP_TASKS");
                return v && std::atoi(v) != 0;
            }();
            if (_stiles_dump_ptr && rank == 0) {
                std::fprintf(stderr, "[STILES_DUMP/pthreads_reduction_semi] total_chol_tasks=%d  worldsize=%d  num_tiles_per_dim=%d  red_tree_separator_level=%d  offsets.size=%zu\n",
                             static_cast<int>(tasks.size()), stile ? stile->world_size : -1,
                             num_tiles_per_dim, tiledMatrix->red_tree_separator_level, offsets.size());
            }
            int _dump_ptr_routine_count[12] = {0};
            const double _dump_ptr_t0 = _stiles_dump_ptr ? omp_get_wtime() : 0.0;

            for (int idx = start; idx < end; ++idx) {

                const std::array<int,7> &t = tasks[idx];
                const int myroutine = t[0];
                const int m = t[1];
                const int k = t[2];
                const int n = t[3];
                const int index1 = t[4];
                const int index2 = t[5];
                const int index3 = t[6];
                (void)m; (void)n;  // silence unused-warning on builds without SS_WAIT_IMP2 macros

                if (_stiles_dump_ptr && myroutine >= 0 && myroutine < 12) {
                    _dump_ptr_routine_count[myroutine]++;
                }

                switch (myroutine) {

                    case 1: { // DPOTRF — banded Cholesky on diagonal tile
                        double *tile_out = chunked_tiles[index1];
                        const sTiles::SemisparseTileMetaCore& semi = semisparse_meta[index1];
                        const sTiles::TileMetaCore& meta = tile_meta[index1];
                        sTiles::StatusCode ssstatus = sTiles::core_dpotrf_upper_banded(meta.height, semi.upper_bw, tile_out);
                        if (ssstatus != sTiles::StatusCode::Success) {
                            std::fprintf(stderr, "sTiles error: matrix is not positive definite (banded tile k=%d).\n", k);
                            ss_abort(); break;
                        }
                        // (k,k) → index1
                        ss_set_done_dp(k, k, index1, 1);
                        break;
                    }

                    case 2: { // DSYRK — symmetric rank-k update into banded diag (general path)
                        // (k,n) → index1
                        SS_COND_WAIT_DP(k, n, index1, 1);
                        const sTiles::SemisparseTileMetaCore& semi_in = semisparse_meta[index1];
                        const int active_cols = semi_in.sa;
                        if (active_cols > 0) {
                            double *tile_in = chunked_tiles[index1];
                            double *tile_out = chunked_tiles[index2];
                            const sTiles::SemisparseTileMetaCore& semi_out = semisparse_meta[index2];
                            const int diag_cols = semi_out.upper_bw + 1;
                            const int rows_in = (tile_meta[index1].height > 0) ? tile_meta[index1].height : tile_size;
                            const int base_row = diag_cols - 1;
                            const int ld_tmp = active_cols;

                            sTiles::core_dsyrk(sTiles::Uplo::Upper, sTiles::Op::Trans,
                                               active_cols, rows_in, mzone,
                                               tile_in, rows_in, 0.0, tmp_tile, ld_tmp);
                            if (semi_in.is_contiguous) {
                                const int aind_start = semi_in.fa;
                                for (int j = 0; j < active_cols; ++j) {
                                    const int col_idx = aind_start + j;
                                    const std::size_t col_base = static_cast<std::size_t>(diag_cols) * col_idx;
                                    const double *tmp_col = tmp_tile + j * ld_tmp;
                                    for (int i = 0; i <= j; ++i) {
                                        tile_out[base_row - (j - i) + col_base] += tmp_col[i];
                                    }
                                }
                            } else {
                                const int *aind = semi_in.aind.data();
                                for (int j = 0; j < active_cols; ++j) {
                                    const int col_idx = aind[j];
                                    const std::size_t col_base = static_cast<std::size_t>(diag_cols) * col_idx;
                                    const double *tmp_col = tmp_tile + j * ld_tmp;
                                    for (int i = 0; i <= j; ++i) {
                                        const int band = col_idx - aind[i];
                                        if (band < diag_cols) {
                                            tile_out[base_row - band + col_base] += tmp_col[i];
                                        }
                                    }
                                }
                            }
                        }
                        break;
                    }

                    case 3: { // DTRSM — banded triangular solve
                        // (k,k) → index2
                        SS_COND_WAIT_DP(k, k, index2, 1);
                        const sTiles::SemisparseTileMetaCore& semi_rhs = semisparse_meta[index1];
                        const int active_cols = semi_rhs.sa;
                        if (active_cols > 0) {
                            double *ss_rhs  = chunked_tiles[index1];
                            double *ss_diag = chunked_tiles[index2];
                            const sTiles::SemisparseTileMetaCore& semi_diag = semisparse_meta[index2];
                            const int rows_rhs = tile_meta[index1].height;
                            const int diag_dim = tile_meta[index2].height;
                            const int kd = semi_diag.upper_bw;

                            lapack_int info = LAPACKE_dtbtrs(LAPACK_COL_MAJOR, 'U', 'T', 'N',
                                                             diag_dim, kd, active_cols,
                                                             ss_diag, kd + 1, ss_rhs, rows_rhs);
                            if (info != 0) {
                                std::fprintf(stderr, "sTiles error: LAPACKE_dtbtrs failed info=%d (tile m=%d, k=%d).\n",
                                             info, m, k);
                                ss_abort(); break;
                            }
                        }
                        // (m,k) → index1
                        ss_set_done_dp(m, k, index1, 1);
                        break;
                    }

                    case 4: { // DGEMM — semisparse, full path_flag dispatch (mirrors imp4)
                        // (k,n) → index1; (m,n) → index2.
                        SS_COND_WAIT_DP(k, n, index1, 1);
                        SS_COND_WAIT_DP(m, n, index2, 1);

                        double *chunk_a = chunked_tiles[index1];
                        double *chunk_b = chunked_tiles[index2];
                        double *chunk_out = chunked_tiles[index3];

                        const sTiles::SemisparseTileMetaCore& semi_a = semisparse_meta[index1];
                        const sTiles::SemisparseTileMetaCore& semi_b = semisparse_meta[index2];

                        const int cols_a = semi_a.sa;
                        const int cols_b = semi_b.sa;
                        const int rows_a = tile_meta[index1].height;
                        const int rows_out = tile_meta[index3].height;

                        const int si_base = idx * 2;
                        const int64_t data_off = scatter_index[si_base];
                        const int path_flag = static_cast<int>(scatter_index[si_base + 1]);

                        if (path_flag == 0) {
                            const int a_start = semi_a.fa;
                            const int b_start = semi_b.fa;
                            cblas_dgemm(CblasColMajor, CblasTrans, CblasNoTrans,
                                        cols_a, cols_b, rows_a, mzone,
                                        chunk_a, rows_a, chunk_b, rows_a,
                                        1.0, chunk_out + a_start + static_cast<std::size_t>(b_start) * rows_out, rows_out);
                        } else if (path_flag == 1 || path_flag == 2) {
                            // Fused (contiguous or scattered) — use general BLAS+scatter form (correctness over imp4 specialization).
                            const int ld_tmp = cols_a;
                            const int32_t* slots = scatter_packed + data_off;
                            sTiles::core_dgemm(sTiles::Op::Trans, sTiles::Op::NoTrans,
                                               cols_a, cols_b, rows_a,
                                               mzone, chunk_a, rows_a, chunk_b, rows_a,
                                               0.0, tmp_tile, ld_tmp);
                            const int *aind_a = semi_a.aind.data();
                            const int a_contig = semi_a.is_contiguous;
                            const int fa_a = semi_a.fa;
                            for (int j = 0; j < cols_b; ++j) {
                                const int slot = slots[j];
                                if (slot < 0) continue;
                                double *out_col = chunk_out + static_cast<std::size_t>(slot) * rows_out;
                                const double *tmp_col = tmp_tile + j * ld_tmp;
                                if (a_contig) {
                                    double *out_col_off = out_col + fa_a;
                                    for (int i = 0; i < cols_a; ++i) out_col_off[i] += tmp_col[i];
                                } else {
                                    for (int i = 0; i < cols_a; ++i) out_col[aind_a[i]] += tmp_col[i];
                                }
                            }
                        } else if (path_flag == 3) {
                            const int ld_tmp = cols_a;
                            const int a_start = semi_a.fa;
                            const int32_t* slots = scatter_packed + data_off;
                            sTiles::core_dgemm(sTiles::Op::Trans, sTiles::Op::NoTrans,
                                               cols_a, cols_b, rows_a,
                                               mzone, chunk_a, rows_a, chunk_b, rows_a,
                                               0.0, tmp_tile, ld_tmp);
                            for (int j = 0; j < cols_b; ++j) {
                                const int slot = slots[j];
                                if (slot < 0) continue;
                                double *out_col = chunk_out + static_cast<std::size_t>(slot) * rows_out + a_start;
                                const double *tmp_col = tmp_tile + j * ld_tmp;
                                for (int i = 0; i < cols_a; ++i) out_col[i] += tmp_col[i];
                            }
                        } else if (path_flag == 4) {
                            const int ld_tmp = cols_a;
                            const int *aind_a = semi_a.aind.data();
                            const int32_t* slots = scatter_packed + data_off;
                            sTiles::core_dgemm(sTiles::Op::Trans, sTiles::Op::NoTrans,
                                               cols_a, cols_b, rows_a,
                                               mzone, chunk_a, rows_a, chunk_b, rows_a,
                                               0.0, tmp_tile, ld_tmp);
                            for (int j = 0; j < cols_b; ++j) {
                                const int slot = slots[j];
                                if (slot < 0) continue;
                                double *out_col = chunk_out + static_cast<std::size_t>(slot) * rows_out;
                                const double *tmp_col = tmp_tile + j * ld_tmp;
                                for (int i = 0; i < cols_a; ++i) out_col[aind_a[i]] += tmp_col[i];
                            }
                        }
                        break;
                    }

                    case 5: { // Tree DSYRK — semisparse → dense scratch.
                        // Scatter is `+=`, so first use must zero the dense scratch tile.
                        // (k,n) → index1
                        SS_COND_WAIT_DP(k, n, index1, 1);
                        const sTiles::SemisparseTileMetaCore& semi_in = semisparse_meta[index1];
                        const int active_cols = semi_in.sa;
                        if (active_cols > 0) {
                            double *chunk_a = chunked_tiles[index1];
                            auto &node5 = tiledMatrix->trees[index2]->nodes[rank];
                            double *scratch = node5.x;
                            if (!node5.dirty) {
                                std::memset(scratch, 0,
                                            static_cast<std::size_t>(tile_size) * tile_size * sizeof(double));
                            }
                            const int rows_a = tile_meta[index1].height;
                            const int ld_tmp = active_cols;

                            // tmp = A^T A   (active_cols × active_cols, upper triangle stored)
                            sTiles::core_dsyrk(sTiles::Uplo::Upper, sTiles::Op::Trans,
                                               active_cols, rows_a, zone,
                                               chunk_a, rows_a, 0.0, tmp_tile, ld_tmp);

                            // Scatter tmp into the dense scratch at columns/rows indexed by semi_in.
                            if (semi_in.is_contiguous) {
                                const int col_start = semi_in.fa;
                                for (int j = 0; j < active_cols; ++j) {
                                    const int col_dst = col_start + j;
                                    const double *tmp_col = tmp_tile + j * ld_tmp;
                                    double *sc_col = scratch + static_cast<std::size_t>(col_dst) * tile_size;
                                    for (int i = 0; i <= j; ++i) {
                                        sc_col[col_start + i] += tmp_col[i];
                                    }
                                }
                            } else {
                                const int *aind = semi_in.aind.data();
                                for (int j = 0; j < active_cols; ++j) {
                                    const int col_dst = aind[j];
                                    const double *tmp_col = tmp_tile + j * ld_tmp;
                                    double *sc_col = scratch + static_cast<std::size_t>(col_dst) * tile_size;
                                    for (int i = 0; i <= j; ++i) {
                                        sc_col[aind[i]] += tmp_col[i];
                                    }
                                }
                            }
                            node5.dirty = 1;
                        }
                        break;
                    }

                    case 6: { // Set dependency flag — diag reduce token = index3
                        tiledMatrix->trees[index2]->dependency[rank] = index3;
                        break;
                    }

                    case 7: { // DGEADD-reduce → banded diag (skip ranks with !dirty)
                        double *tile_out = chunked_tiles[index2];
                        const sTiles::SemisparseTileMetaCore& semi_out = semisparse_meta[index2];
                        const sTiles::TileMetaCore& meta = tile_meta[index2];
                        const int upper_bw = semi_out.upper_bw;
                        const int diag_cols = upper_bw + 1;
                        const int base_row = diag_cols - 1;
                        const int dest_width = (meta.width > 0) ? meta.width : tile_size;

                        for (int rank_idx = 0; rank_idx < STILES_SIZE; ++rank_idx) {
                            if (rank_idx > 0) ss_cond_wait_tree_e_s_t_y_l_e(rank_idx, index3, tiledMatrix->trees[index1]->dependency);
                            if (tiledMatrix->trees[index1]->nodes[rank_idx].dirty) {
                                double *scratch = tiledMatrix->trees[index1]->nodes[rank_idx].x;
                                // For each column j in destination: subtract upper-band rows from dense scratch.
                                for (int j = 0; j < dest_width; ++j) {
                                    const std::size_t col_base = static_cast<std::size_t>(diag_cols) * j;
                                    const double *sc_col = scratch + static_cast<std::size_t>(j) * tile_size;
                                    const int i_lo = (j - upper_bw > 0) ? (j - upper_bw) : 0;
                                    for (int i = i_lo; i <= j; ++i) {
                                        tile_out[base_row - (j - i) + col_base] -= sc_col[i];
                                    }
                                }
                                tiledMatrix->trees[index1]->nodes[rank_idx].dirty = 0;
                            }
                            tiledMatrix->trees[index1]->dependency[rank_idx] = 0;
                        }
                        break;
                    }

                    case 8: { // Tree DGEMM — semisparse × semisparse → dense scratch.
                        // Scatter is `+=`, so first use must zero the dense scratch tile.
                        // (k,n) → index1; (m,n) → index2
                        SS_COND_WAIT_DP(k, n, index1, 1);
                        SS_COND_WAIT_DP(m, n, index2, 1);
                        const sTiles::SemisparseTileMetaCore& semi_a = semisparse_meta[index1];
                        const sTiles::SemisparseTileMetaCore& semi_b = semisparse_meta[index2];
                        const int cols_a = semi_a.sa;
                        const int cols_b = semi_b.sa;
                        if (cols_a > 0 && cols_b > 0) {
                            double *chunk_a = chunked_tiles[index1];
                            double *chunk_b = chunked_tiles[index2];
                            auto &node8 = tiledMatrix->trees[index3]->nodes[rank];
                            double *scratch = node8.x;
                            if (!node8.dirty) {
                                std::memset(scratch, 0,
                                            static_cast<std::size_t>(tile_size) * tile_size * sizeof(double));
                            }
                            const int rows = tile_meta[index1].height;
                            const int ld_tmp = cols_a;

                            // tmp = A^T B   (cols_a × cols_b)
                            sTiles::core_dgemm(sTiles::Op::Trans, sTiles::Op::NoTrans,
                                               cols_a, cols_b, rows,
                                               zone, chunk_a, rows, chunk_b, rows,
                                               0.0, tmp_tile, ld_tmp);

                            // Scatter: scratch[aind_a[i], aind_b[j]] += tmp[i, j]
                            const bool a_contig = semi_a.is_contiguous;
                            const bool b_contig = semi_b.is_contiguous;
                            const int *aind_a = semi_a.aind.data();
                            const int *aind_b = semi_b.aind.data();
                            const int fa_a = semi_a.fa;
                            const int fa_b = semi_b.fa;

                            for (int j = 0; j < cols_b; ++j) {
                                const int col_dst = b_contig ? (fa_b + j) : aind_b[j];
                                const double *tmp_col = tmp_tile + j * ld_tmp;
                                double *sc_col = scratch + static_cast<std::size_t>(col_dst) * tile_size;
                                if (a_contig) {
                                    double *sc_col_off = sc_col + fa_a;
                                    for (int i = 0; i < cols_a; ++i) sc_col_off[i] += tmp_col[i];
                                } else {
                                    for (int i = 0; i < cols_a; ++i) sc_col[aind_a[i]] += tmp_col[i];
                                }
                            }
                            node8.dirty = 1;
                        }
                        break;
                    }

                    case 9: { // Set dependency flag — off-diag reduce token = 165715
                        tiledMatrix->trees[index2]->dependency[rank] = 165715;
                        break;
                    }

                    case 10: { // DGEADD-reduce → semisparse off-diag (skip ranks with !dirty)
                        double *chunk_out = chunked_tiles[index3];
                        const sTiles::SemisparseTileMetaCore& semi_out = semisparse_meta[index3];
                        const sTiles::TileMetaCore& meta = tile_meta[index3];
                        const int sa_out = semi_out.sa;
                        const int rows_out = (meta.height > 0) ? meta.height : tile_size;

                        if (sa_out > 0) {
                            const bool out_contig = semi_out.is_contiguous;
                            const int *aind_out = semi_out.aind.data();
                            const int fa_out = semi_out.fa;

                            for (int rank_idx = 0; rank_idx < STILES_SIZE; ++rank_idx) {
                                if (rank_idx > 0) ss_cond_wait_tree_e_s_t_y_l_e(rank_idx, 165715, tiledMatrix->trees[index1]->dependency);
                                if (!tiledMatrix->trees[index1]->nodes[rank_idx].dirty) {
                                    tiledMatrix->trees[index1]->dependency[rank_idx] = 0;
                                    continue;
                                }
                                double *scratch = tiledMatrix->trees[index1]->nodes[rank_idx].x;
                                // For each output column j: subtract scratch column (semi_out's source column) from chunk_out.
                                for (int j = 0; j < sa_out; ++j) {
                                    const int col_src = out_contig ? (fa_out + j) : aind_out[j];
                                    double *dst_col = chunk_out + static_cast<std::size_t>(j) * rows_out;
                                    const double *sc_col = scratch + static_cast<std::size_t>(col_src) * tile_size;
                                    for (int i = 0; i < rows_out; ++i) {
                                        dst_col[i] -= sc_col[i];
                                    }
                                }
                                tiledMatrix->trees[index1]->nodes[rank_idx].dirty = 0;
                                tiledMatrix->trees[index1]->dependency[rank_idx] = 0;
                            }
                        }
                        break;
                    }

                    default:
                        break;
                }
                if (ss_aborted()) break;
            }
            if (_stiles_dump_ptr) {
                const double _dump_ptr_dt = omp_get_wtime() - _dump_ptr_t0;
                std::fprintf(stderr, "[STILES_DUMP/pthreads_reduction_semi] rank=%d  tasks=[%d,%d)  count=%d  dt=%.4fs  routines: c1=%d c2=%d c3=%d c4=%d c5=%d c7=%d c8=%d c10=%d\n",
                             rank, start, end, end - start, _dump_ptr_dt,
                             _dump_ptr_routine_count[1], _dump_ptr_routine_count[2],
                             _dump_ptr_routine_count[3], _dump_ptr_routine_count[4],
                             _dump_ptr_routine_count[5], _dump_ptr_routine_count[7],
                             _dump_ptr_routine_count[8], _dump_ptr_routine_count[10]);
            }
            ss_finalize_dp();
        }

        // OMP mirror of pthreads_dpotrf_reduction_semi. Same case 1–10 handling,
        // same semisparse↔dense bridging at the tree boundary; only the sync
        // layer differs (dep_* atomics in place of ss_* volatile-int).
        void omp_dpotrf_reduction_semi(TiledMatrix *tiledMatrix, omp_dep_tracker_t* dep_tracker, int worldsize) {

            const int rank = omp_get_thread_num();
            const int N = tiledMatrix->dim;
            const int tile_size = tiledMatrix->tile_size;
            const int num_tiles_per_dim = (N == 0) ? 0 : (N - 1) / tile_size + 1;

            double** __restrict__ const chunked_tiles = tiledMatrix->chunkedDenseTiles;
            const sTiles::SemisparseTileMetaCore* __restrict__ const semisparse_meta = tiledMatrix->semisparseTileMetaCore;
            const sTiles::TileMetaCore* __restrict__ const tile_meta = tiledMatrix->tileMetaCore;

            const auto &tasks = sTiles::get_chol_tasks(tiledMatrix);
            const auto &offsets = sTiles::get_chol_task_offsets(tiledMatrix);
            const int start = (rank < static_cast<int>(offsets.size())) ? offsets[rank] : 0;
            const int end = (rank + 1 < static_cast<int>(offsets.size())) ? offsets[rank + 1] : static_cast<int>(tasks.size());

            if (rank >= tiledMatrix->num_workspaces) {
                sTiles::Logger::error("[reduction_semi_omp] rank ", rank, " >= num_workspaces ", tiledMatrix->num_workspaces);
                return;
            }
            double* __restrict__ tmp_tile = tiledMatrix->workspaces[rank]->aligned_tile();
            const double zone = 1.0;
            const double mzone = -1.0;

            const int64_t* scatter_index = tiledMatrix->chol_scatter_index->data();
            const int32_t* scatter_packed = tiledMatrix->chol_scatter_packed->data();

            dep_init_dp(tiledMatrix, num_tiles_per_dim, tiledMatrix->numActiveTiles, 0);

            const bool _stiles_dump = []() {
                const char* v = std::getenv("STILES_DUMP_TASKS");
                return v && std::atoi(v) != 0;
            }();
            if (_stiles_dump) {
                #pragma omp single nowait
                std::fprintf(stderr, "[STILES_DUMP/reduction_semi] total_chol_tasks=%d  worldsize=%d  num_tiles_per_dim=%d  red_tree_separator_level=%d\n",
                             static_cast<int>(tasks.size()), worldsize, num_tiles_per_dim,
                             tiledMatrix->red_tree_separator_level);
            }
            int _dump_routine_count[5] = {0,0,0,0,0};
            const double _dump_t0 = _stiles_dump ? omp_get_wtime() : 0.0;

            for (int idx = start; idx < end; ++idx) {

                const std::array<int,7> &t = tasks[idx];
                const int myroutine = t[0];
                const int m = t[1];
                const int k = t[2];
                const int n = t[3];
                const int index1 = t[4];
                const int index2 = t[5];
                const int index3 = t[6];
                (void)m; (void)n;
                if (_stiles_dump && myroutine >= 0 && myroutine < 5) {
                    _dump_routine_count[myroutine]++;
                }

                switch (myroutine) {

                    case 1: { // DPOTRF — banded Cholesky on diagonal tile
                        double *tile_out = chunked_tiles[index1];
                        const sTiles::SemisparseTileMetaCore& semi = semisparse_meta[index1];
                        const sTiles::TileMetaCore& meta = tile_meta[index1];
                        sTiles::StatusCode ssstatus = sTiles::core_dpotrf_upper_banded(meta.height, semi.upper_bw, tile_out);
                        if (ssstatus != sTiles::StatusCode::Success) {
                            std::fprintf(stderr, "sTiles error: matrix is not positive definite (banded tile k=%d).\n", k);
                            dep_abort_all(); break;
                        }
                        // (k,k) → index1
                        dep_set_done_dp(k, k, index1, 1);
                        break;
                    }

                    case 2: { // DSYRK — semi off-diag → banded diag
                        // (k,n) → index1
                        dep_wait_for_dp(k, n, index1, 1);
                        const sTiles::SemisparseTileMetaCore& semi_in = semisparse_meta[index1];
                        const int active_cols = semi_in.sa;
                        if (active_cols > 0) {
                            double *tile_in = chunked_tiles[index1];
                            double *tile_out = chunked_tiles[index2];
                            const sTiles::SemisparseTileMetaCore& semi_out = semisparse_meta[index2];
                            const int diag_cols = semi_out.upper_bw + 1;
                            const int rows_in = (tile_meta[index1].height > 0) ? tile_meta[index1].height : tile_size;
                            const int base_row = diag_cols - 1;
                            const int ld_tmp = active_cols;

                            sTiles::core_dsyrk(sTiles::Uplo::Upper, sTiles::Op::Trans,
                                               active_cols, rows_in, mzone,
                                               tile_in, rows_in, 0.0, tmp_tile, ld_tmp);
                            if (semi_in.is_contiguous) {
                                const int aind_start = semi_in.fa;
                                for (int j = 0; j < active_cols; ++j) {
                                    const int col_idx = aind_start + j;
                                    const std::size_t col_base = static_cast<std::size_t>(diag_cols) * col_idx;
                                    const double *tmp_col = tmp_tile + j * ld_tmp;
                                    for (int i = 0; i <= j; ++i) {
                                        tile_out[base_row - (j - i) + col_base] += tmp_col[i];
                                    }
                                }
                            } else {
                                const int *aind = semi_in.aind.data();
                                for (int j = 0; j < active_cols; ++j) {
                                    const int col_idx = aind[j];
                                    const std::size_t col_base = static_cast<std::size_t>(diag_cols) * col_idx;
                                    const double *tmp_col = tmp_tile + j * ld_tmp;
                                    for (int i = 0; i <= j; ++i) {
                                        const int band = col_idx - aind[i];
                                        if (band < diag_cols) {
                                            tile_out[base_row - band + col_base] += tmp_col[i];
                                        }
                                    }
                                }
                            }
                        }
                        break;
                    }

                    case 3: { // DTRSM — banded triangular solve
                        // (k,k) → index2
                        dep_wait_for_dp(k, k, index2, 1);
                        const sTiles::SemisparseTileMetaCore& semi_rhs = semisparse_meta[index1];
                        const int active_cols = semi_rhs.sa;
                        if (active_cols > 0) {
                            double *ss_rhs  = chunked_tiles[index1];
                            double *ss_diag = chunked_tiles[index2];
                            const sTiles::SemisparseTileMetaCore& semi_diag = semisparse_meta[index2];
                            const int rows_rhs = tile_meta[index1].height;
                            const int diag_dim = tile_meta[index2].height;
                            const int kd = semi_diag.upper_bw;

                            lapack_int info = LAPACKE_dtbtrs(LAPACK_COL_MAJOR, 'U', 'T', 'N',
                                                             diag_dim, kd, active_cols,
                                                             ss_diag, kd + 1, ss_rhs, rows_rhs);
                            if (info != 0) {
                                std::fprintf(stderr, "sTiles error: LAPACKE_dtbtrs failed info=%d (tile m=%d, k=%d).\n",
                                             info, m, k);
                                dep_abort_all(); break;
                            }
                        }
                        // (m,k) → index1
                        dep_set_done_dp(m, k, index1, 1);
                        break;
                    }

                    case 4: { // DGEMM — semi, full path_flag dispatch
                        // (k,n) → index1; (m,n) → index2
                        dep_wait_for_dp(k, n, index1, 1);
                        dep_wait_for_dp(m, n, index2, 1);

                        double *chunk_a = chunked_tiles[index1];
                        double *chunk_b = chunked_tiles[index2];
                        double *chunk_out = chunked_tiles[index3];

                        const sTiles::SemisparseTileMetaCore& semi_a = semisparse_meta[index1];
                        const sTiles::SemisparseTileMetaCore& semi_b = semisparse_meta[index2];

                        const int cols_a = semi_a.sa;
                        const int cols_b = semi_b.sa;
                        const int rows_a = tile_meta[index1].height;
                        const int rows_out = tile_meta[index3].height;

                        const int si_base = idx * 2;
                        const int64_t data_off = scatter_index[si_base];
                        const int path_flag = static_cast<int>(scatter_index[si_base + 1]);

                        if (path_flag == 0) {
                            const int a_start = semi_a.fa;
                            const int b_start = semi_b.fa;
                            cblas_dgemm(CblasColMajor, CblasTrans, CblasNoTrans,
                                        cols_a, cols_b, rows_a, mzone,
                                        chunk_a, rows_a, chunk_b, rows_a,
                                        1.0, chunk_out + a_start + static_cast<std::size_t>(b_start) * rows_out, rows_out);
                        } else if (path_flag == 1 || path_flag == 2) {
                            const int ld_tmp = cols_a;
                            const int32_t* slots = scatter_packed + data_off;
                            sTiles::core_dgemm(sTiles::Op::Trans, sTiles::Op::NoTrans,
                                               cols_a, cols_b, rows_a,
                                               mzone, chunk_a, rows_a, chunk_b, rows_a,
                                               0.0, tmp_tile, ld_tmp);
                            const int *aind_a = semi_a.aind.data();
                            const int a_contig = semi_a.is_contiguous;
                            const int fa_a = semi_a.fa;
                            for (int j = 0; j < cols_b; ++j) {
                                const int slot = slots[j];
                                if (slot < 0) continue;
                                double *out_col = chunk_out + static_cast<std::size_t>(slot) * rows_out;
                                const double *tmp_col = tmp_tile + j * ld_tmp;
                                if (a_contig) {
                                    double *out_col_off = out_col + fa_a;
                                    for (int i = 0; i < cols_a; ++i) out_col_off[i] += tmp_col[i];
                                } else {
                                    for (int i = 0; i < cols_a; ++i) out_col[aind_a[i]] += tmp_col[i];
                                }
                            }
                        } else if (path_flag == 3) {
                            const int ld_tmp = cols_a;
                            const int a_start = semi_a.fa;
                            const int32_t* slots = scatter_packed + data_off;
                            sTiles::core_dgemm(sTiles::Op::Trans, sTiles::Op::NoTrans,
                                               cols_a, cols_b, rows_a,
                                               mzone, chunk_a, rows_a, chunk_b, rows_a,
                                               0.0, tmp_tile, ld_tmp);
                            for (int j = 0; j < cols_b; ++j) {
                                const int slot = slots[j];
                                if (slot < 0) continue;
                                double *out_col = chunk_out + static_cast<std::size_t>(slot) * rows_out + a_start;
                                const double *tmp_col = tmp_tile + j * ld_tmp;
                                for (int i = 0; i < cols_a; ++i) out_col[i] += tmp_col[i];
                            }
                        } else if (path_flag == 4) {
                            const int ld_tmp = cols_a;
                            const int *aind_a = semi_a.aind.data();
                            const int32_t* slots = scatter_packed + data_off;
                            sTiles::core_dgemm(sTiles::Op::Trans, sTiles::Op::NoTrans,
                                               cols_a, cols_b, rows_a,
                                               mzone, chunk_a, rows_a, chunk_b, rows_a,
                                               0.0, tmp_tile, ld_tmp);
                            for (int j = 0; j < cols_b; ++j) {
                                const int slot = slots[j];
                                if (slot < 0) continue;
                                double *out_col = chunk_out + static_cast<std::size_t>(slot) * rows_out;
                                const double *tmp_col = tmp_tile + j * ld_tmp;
                                for (int i = 0; i < cols_a; ++i) out_col[aind_a[i]] += tmp_col[i];
                            }
                        }
                        break;
                    }

                    case 5: { // Tree DSYRK — semisparse → dense scratch.
                        // Scatter is `+=`, so first use must zero the dense scratch tile.
                        // (k,n) → index1
                        dep_wait_for_dp(k, n, index1, 1);
                        const sTiles::SemisparseTileMetaCore& semi_in = semisparse_meta[index1];
                        const int active_cols = semi_in.sa;
                        if (active_cols > 0) {
                            double *chunk_a = chunked_tiles[index1];
                            auto &node5 = tiledMatrix->trees[index2]->nodes[rank];
                            double *scratch = node5.x;
                            if (!node5.dirty) {
                                std::memset(scratch, 0,
                                            static_cast<std::size_t>(tile_size) * tile_size * sizeof(double));
                            }
                            const int rows_a = tile_meta[index1].height;
                            const int ld_tmp = active_cols;

                            sTiles::core_dsyrk(sTiles::Uplo::Upper, sTiles::Op::Trans,
                                               active_cols, rows_a, zone,
                                               chunk_a, rows_a, 0.0, tmp_tile, ld_tmp);

                            if (semi_in.is_contiguous) {
                                const int col_start = semi_in.fa;
                                for (int j = 0; j < active_cols; ++j) {
                                    const int col_dst = col_start + j;
                                    const double *tmp_col = tmp_tile + j * ld_tmp;
                                    double *sc_col = scratch + static_cast<std::size_t>(col_dst) * tile_size;
                                    for (int i = 0; i <= j; ++i) {
                                        sc_col[col_start + i] += tmp_col[i];
                                    }
                                }
                            } else {
                                const int *aind = semi_in.aind.data();
                                for (int j = 0; j < active_cols; ++j) {
                                    const int col_dst = aind[j];
                                    const double *tmp_col = tmp_tile + j * ld_tmp;
                                    double *sc_col = scratch + static_cast<std::size_t>(col_dst) * tile_size;
                                    for (int i = 0; i <= j; ++i) {
                                        sc_col[aind[i]] += tmp_col[i];
                                    }
                                }
                            }
                            node5.dirty = 1;
                        }
                        break;
                    }

                    case 6: { // Set dependency flag
                        tiledMatrix->trees[index2]->dependency[rank] = index3;
                        break;
                    }

                    case 7: { // DGEADD-reduce → banded diag (skip ranks with !dirty)
                        double *tile_out = chunked_tiles[index2];
                        const sTiles::SemisparseTileMetaCore& semi_out = semisparse_meta[index2];
                        const sTiles::TileMetaCore& meta = tile_meta[index2];
                        const int upper_bw = semi_out.upper_bw;
                        const int diag_cols = upper_bw + 1;
                        const int base_row = diag_cols - 1;
                        const int dest_width = (meta.width > 0) ? meta.width : tile_size;

                        for (int rank_idx = 0; rank_idx < worldsize; ++rank_idx) {
                            if (rank_idx > 0) dep_wait_for_tree(rank_idx, index3, tiledMatrix->trees[index1]->dependency);
                            if (tiledMatrix->trees[index1]->nodes[rank_idx].dirty) {
                                double *scratch = tiledMatrix->trees[index1]->nodes[rank_idx].x;
                                for (int j = 0; j < dest_width; ++j) {
                                    const std::size_t col_base = static_cast<std::size_t>(diag_cols) * j;
                                    const double *sc_col = scratch + static_cast<std::size_t>(j) * tile_size;
                                    const int i_lo = (j - upper_bw > 0) ? (j - upper_bw) : 0;
                                    for (int i = i_lo; i <= j; ++i) {
                                        tile_out[base_row - (j - i) + col_base] -= sc_col[i];
                                    }
                                }
                                tiledMatrix->trees[index1]->nodes[rank_idx].dirty = 0;
                            }
                            tiledMatrix->trees[index1]->dependency[rank_idx] = 0;
                        }
                        break;
                    }

                    case 8: { // Tree DGEMM — semi × semi → dense scratch.
                        // Scatter is `+=`, so first use must zero the dense scratch tile.
                        // (k,n) → index1; (m,n) → index2
                        dep_wait_for_dp(k, n, index1, 1);
                        dep_wait_for_dp(m, n, index2, 1);
                        const sTiles::SemisparseTileMetaCore& semi_a = semisparse_meta[index1];
                        const sTiles::SemisparseTileMetaCore& semi_b = semisparse_meta[index2];
                        const int cols_a = semi_a.sa;
                        const int cols_b = semi_b.sa;
                        if (cols_a > 0 && cols_b > 0) {
                            double *chunk_a = chunked_tiles[index1];
                            double *chunk_b = chunked_tiles[index2];
                            auto &node8 = tiledMatrix->trees[index3]->nodes[rank];
                            double *scratch = node8.x;
                            if (!node8.dirty) {
                                std::memset(scratch, 0,
                                            static_cast<std::size_t>(tile_size) * tile_size * sizeof(double));
                            }
                            const int rows = tile_meta[index1].height;
                            const int ld_tmp = cols_a;

                            sTiles::core_dgemm(sTiles::Op::Trans, sTiles::Op::NoTrans,
                                               cols_a, cols_b, rows,
                                               zone, chunk_a, rows, chunk_b, rows,
                                               0.0, tmp_tile, ld_tmp);

                            const bool a_contig = semi_a.is_contiguous;
                            const bool b_contig = semi_b.is_contiguous;
                            const int *aind_a = semi_a.aind.data();
                            const int *aind_b = semi_b.aind.data();
                            const int fa_a = semi_a.fa;
                            const int fa_b = semi_b.fa;

                            for (int j = 0; j < cols_b; ++j) {
                                const int col_dst = b_contig ? (fa_b + j) : aind_b[j];
                                const double *tmp_col = tmp_tile + j * ld_tmp;
                                double *sc_col = scratch + static_cast<std::size_t>(col_dst) * tile_size;
                                if (a_contig) {
                                    double *sc_col_off = sc_col + fa_a;
                                    for (int i = 0; i < cols_a; ++i) sc_col_off[i] += tmp_col[i];
                                } else {
                                    for (int i = 0; i < cols_a; ++i) sc_col[aind_a[i]] += tmp_col[i];
                                }
                            }
                            node8.dirty = 1;
                        }
                        break;
                    }

                    case 9: { // Set dependency flag — off-diag reduce token
                        tiledMatrix->trees[index2]->dependency[rank] = 165715;
                        break;
                    }

                    case 10: { // DGEADD-reduce → semisparse off-diag (skip ranks with !dirty)
                        double *chunk_out = chunked_tiles[index3];
                        const sTiles::SemisparseTileMetaCore& semi_out = semisparse_meta[index3];
                        const sTiles::TileMetaCore& meta = tile_meta[index3];
                        const int sa_out = semi_out.sa;
                        const int rows_out = (meta.height > 0) ? meta.height : tile_size;

                        if (sa_out > 0) {
                            const bool out_contig = semi_out.is_contiguous;
                            const int *aind_out = semi_out.aind.data();
                            const int fa_out = semi_out.fa;

                            for (int rank_idx = 0; rank_idx < worldsize; ++rank_idx) {
                                if (rank_idx > 0) dep_wait_for_tree(rank_idx, 165715, tiledMatrix->trees[index1]->dependency);
                                if (tiledMatrix->trees[index1]->nodes[rank_idx].dirty) {
                                    double *scratch = tiledMatrix->trees[index1]->nodes[rank_idx].x;
                                    for (int j = 0; j < sa_out; ++j) {
                                        const int col_src = out_contig ? (fa_out + j) : aind_out[j];
                                        double *dst_col = chunk_out + static_cast<std::size_t>(j) * rows_out;
                                        const double *sc_col = scratch + static_cast<std::size_t>(col_src) * tile_size;
                                        for (int i = 0; i < rows_out; ++i) {
                                            dst_col[i] -= sc_col[i];
                                        }
                                    }
                                    tiledMatrix->trees[index1]->nodes[rank_idx].dirty = 0;
                                }
                                tiledMatrix->trees[index1]->dependency[rank_idx] = 0;
                            }
                        }
                        break;
                    }

                    default:
                        break;
                }
                if (dep_is_aborted()) break;
            }
            if (_stiles_dump) {
                const double _dump_dt = omp_get_wtime() - _dump_t0;
                #pragma omp critical
                std::fprintf(stderr, "[STILES_DUMP/reduction_semi] rank=%d  tasks=[%d,%d)  count=%d  dt=%.4fs  routines: c1=%d c2=%d c3=%d c4=%d\n",
                             rank, start, end, end - start, _dump_dt,
                             _dump_routine_count[1], _dump_routine_count[2],
                             _dump_routine_count[3], _dump_routine_count[4]);
            }
            dep_finalize_dp();
        }

