        // Tile-layout helpers. When STILES_MERGE_TILES is defined, the trailing
        // fragment (N % tile_size) is folded into the previous tile so the new
        // "last tile" is up to (2·tile_size − 1) wide. Off by default.
        //
        // The kernel side honors the merged sizes; full enablement also
        // requires the symbolic side to (a) populate tile_meta[last].height/.width
        // with the merged dim, (b) allocate denseTiles[last] / chunked_tiles[last]
        // / tree scratch large enough, and (c) emit tasks using the merged
        // num_tiles. Until those land, leave the flag undefined.
        static inline int sTiles_layout_num_tiles(int N, int tile_size) {
            if (N == 0 || tile_size <= 0) return 0;
            const int raw = (N - 1) / tile_size + 1;
#ifdef STILES_MERGE_TILES
            const int has_tail = ((N % tile_size) != 0);
            return (raw >= 2 && has_tail) ? (raw - 1) : raw;
#else
            return raw;
#endif
        }

        // Width of tile k (also its LDA, since dense tiles are square column-major).
        // For non-last tiles this is tile_size; the last tile carries the
        // trailing dimension (merged or fragment depending on the flag).
        static inline int sTiles_layout_tile_dim(int k, int N, int tile_size, int num_tiles) {
#ifdef STILES_MERGE_TILES
            return (k < num_tiles - 1) ? tile_size
                                       : (N - (num_tiles - 1) * tile_size);
#else
            const int full = (tile_size > 0) ? (N / tile_size) : 0;
            return (k < full) ? tile_size : (N % tile_size);
#endif
        }


