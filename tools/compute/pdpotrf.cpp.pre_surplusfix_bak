        void pthreads_dpotrf_full_dense(TiledMatrix *tiledMatrix, stiles_context_t *stile, int variant) {
            
            const int rank = STILES_RANK;
            const int worldsize = STILES_SIZE;
            const int N = tiledMatrix->dim;
            const int tile_size = tiledMatrix->tile_size;
            const int num_tiles = tiledMatrix->dimTiledMatrix;

            const double zone = 1.0;
            const double mzone = -1.0;

            // Variant 1: Single tile - just one POTRF call
            if (variant == 1) {
                if (rank == 0 && tiledMatrix->denseTiles && tiledMatrix->denseTiles[0]) {
                    double* tile = tiledMatrix->denseTiles[0];
                    sTiles::StatusCode status = sTiles::core_dpotrf(sTiles::Uplo::Upper, N, tile, N);
                    if (status != sTiles::StatusCode::Success) {
                        std::fprintf(stderr, "sTiles error: matrix is not positive definite.\n");
                        ss_abort();
                    }
                }
                return;
            }

            // Variant 2: Scaled dense with all upper triangular tiles
            // Upper triangular tile index: upper_idx(i,j) = i * num_tiles - (i * (i - 1)) / 2 + (j - i)
            auto upper_idx = [num_tiles](int i, int j) -> int {
                return i * num_tiles - (i * (i - 1)) / 2 + (j - i);
            };

            // Calculate tile dimensions
            auto tile_dim = [N, tile_size, num_tiles](int t) -> int {
                return (t == num_tiles - 1) ? (N - t * tile_size) : tile_size;
            };

            ss_init_dp(tiledMatrix, num_tiles, tiledMatrix->numActiveTiles, 0);

            // Iterate through k, m, n similar to STYLE_GREEN_TREE_PHASE_1
            int k = 0;
            int m = rank;
            while (m >= num_tiles) {
                k++;
                m = m - num_tiles + k;
            }
            int n = 0;

            while (k < num_tiles && m < num_tiles) {
                // Compute next iteration values
                int next_n = n;
                int next_m = m;
                int next_k = k;

                next_n++;
                if (next_n > next_k) {
                    next_m += worldsize;
                    while (next_m >= num_tiles && next_k < num_tiles) {
                        next_k++;
                        next_m = next_m - num_tiles + next_k;
                    }
                    next_n = 0;
                }

                // Get tile dimensions
                const int tempkn = tile_dim(k);
                const int tempmn = tile_dim(m);
                const int ldak = tile_dim(k);
                const int ldan = tile_dim(n);

                // For dense matrix, all tiles exist - no on_off_tiles check needed
                if (m == k) {
                    if (n == k) {
                        // Case 1: POTRF on diagonal tile (k, k)
                        const int idx_kk = upper_idx(k, k);
                        double* tile_out = tiledMatrix->denseTiles[idx_kk];
                        if (tile_out) {
                            sTiles::StatusCode status = sTiles::core_dpotrf(sTiles::Uplo::Upper, tempkn, tile_out, ldak);
                            if (status != sTiles::StatusCode::Success) {
                                std::fprintf(stderr, "sTiles error: matrix is not positive definite (tile k=%d).\n", k);
                                ss_abort();
                            }
                        }
                        // (k,k) → idx_kk
                        ss_set_done_dp(k, k, idx_kk, 1);
                    } else {
                        // Case 2: SYRK - update diagonal tile (k, k) with tile (n, k)
                        const int idx_nk = upper_idx(n, k);
                        const int idx_kk = upper_idx(k, k);

                        // wait on (k,n), which is the (n,k) tile → idx_nk
                        SS_COND_WAIT_DP(k, n, idx_nk, 1);
                        double* tile_in = tiledMatrix->denseTiles[idx_nk];
                        double* tile_out = tiledMatrix->denseTiles[idx_kk];
                        if (tile_in && tile_out) {
                            sTiles::core_dsyrk(sTiles::Uplo::Upper, sTiles::Op::Trans, tempkn, tile_size, mzone, tile_in, ldan, zone, tile_out, ldak);
                        }
                    }
                } else {
                    if (n == k) {
                        // Case 3: TRSM - solve for tile (k, m)
                        const int idx_km = upper_idx(k, m);
                        const int idx_kk = upper_idx(k, k);

                        // wait on (k,k) → idx_kk
                        SS_COND_WAIT_DP(k, k, idx_kk, 1);
                        double* tile_rhs = tiledMatrix->denseTiles[idx_kk];
                        double* tile_out = tiledMatrix->denseTiles[idx_km];
                        if (tile_rhs && tile_out) {
                            sTiles::core_dtrsm(sTiles::Side::Left, sTiles::Uplo::Upper, sTiles::Op::Trans, sTiles::Diag::NonUnit, tile_size, tempmn, zone, tile_rhs, ldak, tile_out, ldak);
                        }
                        // (m,k) → idx_km
                        ss_set_done_dp(m, k, idx_km, 1);
                    } else {
                        // Case 4: GEMM - update tile (k, m) with tiles (n, k) and (n, m)
                        const int idx_nk = upper_idx(n, k);
                        const int idx_nm = upper_idx(n, m);
                        const int idx_km = upper_idx(k, m);

                        // wait on (k,n) → idx_nk; (m,n) → idx_nm
                        SS_COND_WAIT_DP(k, n, idx_nk, 1);
                        SS_COND_WAIT_DP(m, n, idx_nm, 1);
                        double* tile_a = tiledMatrix->denseTiles[idx_nk];
                        double* tile_b = tiledMatrix->denseTiles[idx_nm];
                        double* tile_out = tiledMatrix->denseTiles[idx_km];
                        if (tile_out && tile_a && tile_b) {
                            sTiles::core_dgemm(sTiles::Op::Trans, sTiles::Op::NoTrans, tile_size, tempmn, tile_size, mzone, tile_a, ldan, tile_b, ldan, zone, tile_out, ldak);
                        }
                    }
                }

                if (ss_aborted()) break;

                // Move to next iteration
                n = next_n;
                m = next_m;
                k = next_k;
            }

            ss_finalize_dp();
        }

        void omp_dpotrf_full_dense(TiledMatrix *tiledMatrix, omp_dep_tracker_t* dep_tracker, int variant, int worldsize) {
            // OMP mirror of pthreads_dpotrf_full_dense. Same (k,m,n) walk that
            // generates the chol task graph on the fly (no precomputed task
            // list) — used by the unboosted dense branch.

            const int rank = omp_get_thread_num();
            const int N = tiledMatrix->dim;
            const int tile_size = tiledMatrix->tile_size;
            const int num_tiles = tiledMatrix->dimTiledMatrix;

            const double zone = 1.0;
            const double mzone = -1.0;

            // Variant 1: Single tile — one POTRF on the whole matrix by thread 0.
            if (variant == 1) {
                if (rank == 0 && tiledMatrix->denseTiles && tiledMatrix->denseTiles[0]) {
                    double* tile = tiledMatrix->denseTiles[0];
                    sTiles::StatusCode status = sTiles::core_dpotrf(sTiles::Uplo::Upper, N, tile, N);
                    if (status != sTiles::StatusCode::Success) {
                        std::fprintf(stderr, "sTiles error: matrix is not positive definite.\n");
                        dep_tracker->abort_flag.store(true, std::memory_order_release);
                    }
                }
                return;
            }

            // Variant 2: Scaled dense with all upper triangular tiles.
            auto upper_idx = [num_tiles](int i, int j) -> int {
                return i * num_tiles - (i * (i - 1)) / 2 + (j - i);
            };

            auto tile_dim = [N, tile_size, num_tiles](int t) -> int {
                return (t == num_tiles - 1) ? (N - t * tile_size) : tile_size;
            };

            dep_init_dp(tiledMatrix, num_tiles, tiledMatrix->numActiveTiles, 0);

            int k = 0;
            int m = rank;
            while (m >= num_tiles) {
                k++;
                m = m - num_tiles + k;
            }
            int n = 0;

            while (k < num_tiles && m < num_tiles) {
                int next_n = n;
                int next_m = m;
                int next_k = k;

                next_n++;
                if (next_n > next_k) {
                    next_m += worldsize;
                    while (next_m >= num_tiles && next_k < num_tiles) {
                        next_k++;
                        next_m = next_m - num_tiles + next_k;
                    }
                    next_n = 0;
                }

                const int tempkn = tile_dim(k);
                const int tempmn = tile_dim(m);
                const int ldak = tile_dim(k);
                const int ldan = tile_dim(n);

                if (m == k) {
                    if (n == k) {
                        // Case 1: POTRF on diagonal tile (k, k)
                        const int idx_kk = upper_idx(k, k);
                        double* tile_out = tiledMatrix->denseTiles[idx_kk];
                        if (tile_out) {
                            sTiles::StatusCode status = sTiles::core_dpotrf(sTiles::Uplo::Upper, tempkn, tile_out, ldak);
                            if (status != sTiles::StatusCode::Success) {
                                std::fprintf(stderr, "sTiles error: matrix is not positive definite (tile k=%d).\n", k);
                                dep_abort_all();
                            }
                        }
                        // (k,k) → idx_kk
                        dep_set_done_dp(k, k, idx_kk, 1);
                    } else {
                        // Case 2: SYRK — update diagonal tile (k, k) with tile (n, k)
                        const int idx_nk = upper_idx(n, k);
                        const int idx_kk = upper_idx(k, k);

                        // wait on (k,n) which is the (n,k) tile → idx_nk
                        dep_wait_for_dp(k, n, idx_nk, 1);
                        double* tile_in = tiledMatrix->denseTiles[idx_nk];
                        double* tile_out = tiledMatrix->denseTiles[idx_kk];
                        if (tile_in && tile_out) {
                            sTiles::core_dsyrk(sTiles::Uplo::Upper, sTiles::Op::Trans, tempkn, tile_size, mzone, tile_in, ldan, zone, tile_out, ldak);
                        }
                    }
                } else {
                    if (n == k) {
                        // Case 3: TRSM — solve for tile (k, m)
                        const int idx_km = upper_idx(k, m);
                        const int idx_kk = upper_idx(k, k);

                        // wait on (k,k) → idx_kk
                        dep_wait_for_dp(k, k, idx_kk, 1);
                        double* tile_rhs = tiledMatrix->denseTiles[idx_kk];
                        double* tile_out = tiledMatrix->denseTiles[idx_km];
                        if (tile_rhs && tile_out) {
                            sTiles::core_dtrsm(sTiles::Side::Left, sTiles::Uplo::Upper, sTiles::Op::Trans, sTiles::Diag::NonUnit, tile_size, tempmn, zone, tile_rhs, ldak, tile_out, ldak);
                        }
                        // (m,k) → idx_km
                        dep_set_done_dp(m, k, idx_km, 1);
                    } else {
                        // Case 4: GEMM — update tile (k, m) with tiles (n, k) and (n, m)
                        const int idx_nk = upper_idx(n, k);
                        const int idx_nm = upper_idx(n, m);
                        const int idx_km = upper_idx(k, m);

                        // wait on (k,n) → idx_nk; (m,n) → idx_nm
                        dep_wait_for_dp(k, n, idx_nk, 1);
                        dep_wait_for_dp(m, n, idx_nm, 1);
                        double* tile_a = tiledMatrix->denseTiles[idx_nk];
                        double* tile_b = tiledMatrix->denseTiles[idx_nm];
                        double* tile_out = tiledMatrix->denseTiles[idx_km];
                        if (tile_out && tile_a && tile_b) {
                            sTiles::core_dgemm(sTiles::Op::Trans, sTiles::Op::NoTrans, tile_size, tempmn, tile_size, mzone, tile_a, ldan, tile_b, ldan, zone, tile_out, ldak);
                        }
                    }
                }

                if (dep_is_aborted()) break;

                n = next_n;
                m = next_m;
                k = next_k;
            }

            dep_finalize_dp();
        }


        // stiles_control_params used:
        //   [3]  TILE_TYPE    — 0 dense, 1 semisparse, 2 nonunif
        //   [14] SERIAL_MODE  — 0 ⇒ Serial::* worker when STILES_SIZE == 1
        void pthreads_pdpotrf(stiles_context_t *stile) {

            static int* stiles_control_params = sTiles_get_params();

            TiledMatrix* tiledMatrix = nullptr;
            sTiles::unpack_args(stile, tiledMatrix);

            if (!tiledMatrix) {
                std::cout << "Error: null tiledMatrix in stiles_pdpotrf" << std::endl;
                return;
            }

            // Reset chol_info before factorization (rank 0 only to avoid races)
            if (STILES_RANK == 0) {
                tiledMatrix->chol_info.store(0, std::memory_order_relaxed);
            }

            if (tiledMatrix->use_boosted_e_trick) {

                // params[3]  = tile_type_mode (0 dense, 1 semisparse, 2 nonunif)
                // params[14] = parallel knob (0 → Serial path when STILES_SIZE==1;
                //              any other value → multi-core path).
                const int  tile_type_mode = stiles_control_params[3];
                const bool serial_path    = (STILES_SIZE == 1 && stiles_control_params[14] == 0);
                const bool has_semisparse = tiledMatrix->chunkedDenseTiles && tiledMatrix->semisparseTileMetaCore;
                const bool tree_active    = (tiledMatrix->red_tree_separator_level > 0);

                if (tree_active) {
                    // Tree-reduction path (red_tree_separator_level > 0).
                    if (tile_type_mode == 0) {
                        // Dense tree path. Single worker for both serial and parallel —
                        // ss_init/ss_cond_wait handle the STILES_SIZE==1 degenerate case.
                        sTiles::Process::pthreads_dpotrf_reduction_dense(tiledMatrix, stile);
                    } else if (tile_type_mode == 1) {
                        // Semisparse tree path. Bridges dense per-rank scratch tiles
                        // with semisparse/banded destination storage at cases 5/7/8/10.
                        // Falls back to dense if the semisparse arrays weren't built
                        // (e.g. single-tile matrices).
                        if (has_semisparse) {
                            sTiles::Process::pthreads_dpotrf_reduction_semi(tiledMatrix, stile);
                        } else {
                            sTiles::Process::pthreads_dpotrf_reduction_dense(tiledMatrix, stile);
                        }
                    } else {
                        if (STILES_RANK == 0) {
                            sTiles::Logger::error("pthreads_pdpotrf: tile_type_mode=", tile_type_mode,
                                                  " + tree-reduction path unsupported.");
                        }
                        stile->ss_abort = 1;
                    }

                } else if (tile_type_mode == 0) {
                    // Dense mode
                    if (serial_path) {
                        sTiles::Process::pthreads_dpotrf_expansion_dense_serial(tiledMatrix, stile);
                    } else {
                        sTiles::Process::pthreads_dpotrf_expansion_dense_parallel(tiledMatrix, stile);
                    }

                } else if (tile_type_mode == 1) {
                    // Semisparse mode
                    if (has_semisparse) {
                        if (serial_path) {
                            sTiles::Process::pthreads_dpotrf_expansion_semi_serial_imp4(tiledMatrix, stile);
                        } else {
                            sTiles::Process::pthreads_dpotrf_expansion_semi_parallel_imp4(tiledMatrix, stile);
                        }
                    } else {
                        // Fallback to dense mode (e.g., for single-tile matrices)
                        sTiles::Process::pthreads_dpotrf_expansion_dense_parallel(tiledMatrix, stile);
                    }

                } else {
                    // tile_type_mode == 2 (nonunif) is expected to be handled
                    // upstream by sTiles::sparse (see dpotrf.cpp short-circuit on
                    // scheme->sparse_handle). Reaching here means preprocessing
                    // didn't build a sparse_handle — flag it.
                    sTiles::Logger::error("pthreads_pdpotrf: tile_type_mode=",
                                            tile_type_mode,
                                            " has no in-pdpotrf path; expected sparse_handle to short-circuit.");
                    stile->ss_abort = 1;
                }
            } else {
                // Dense variants 1 and 2 without pre-collected tasks.
                // Variant 1: single tile (numActiveTiles == 1, dimTiledMatrix == 1)
                // Variant 2: scaled dense (numActiveTiles == triangular_size)
                const int num_active = tiledMatrix->numActiveTiles;
                const int dim_tiled  = tiledMatrix->dimTiledMatrix;
                const int tri_size   = tiledMatrix->triangular_size;

                if (num_active == 1 && dim_tiled == 1) {
                    sTiles::Process::pthreads_dpotrf_full_dense(tiledMatrix, stile, 1);
                } else if (num_active == tri_size && tri_size > 0) {
                    sTiles::Process::pthreads_dpotrf_full_dense(tiledMatrix, stile, 2);
                }
            }

            // Record Cholesky status: 0 = success, 1 = not positive definite
            if (STILES_RANK == 0) {
                tiledMatrix->chol_info.store(stile->ss_abort ? 1 : 0, std::memory_order_release);
            }
        }

        void omp_pdpotrf(TiledMatrix* tiledMatrix, omp_dep_tracker_t* dep_tracker, int worldsize) {

            static int* stiles_control_params = sTiles_get_params();

            if (!tiledMatrix) {
                #pragma omp single
                std::cerr << "Error: null tiledMatrix in omp_pdpotrf" << std::endl;
                return;
            }

            // Reset chol_info before factorization (single thread)
            #pragma omp single
            { tiledMatrix->chol_info.store(0, std::memory_order_relaxed); }

            if (tiledMatrix->use_boosted_e_trick) {

                // params[3]  = tile_type_mode (0 dense, 1 semisparse, 2 nonunif)
                // params[14] = parallel knob (0 → Serial path when worldsize==1)
                const int  tile_type_mode = stiles_control_params[3];
                const bool serial_path    = (worldsize == 1 && stiles_control_params[14] == 0);
                const bool has_semisparse = tiledMatrix->chunkedDenseTiles && tiledMatrix->semisparseTileMetaCore;
                const bool tree_active    = (tiledMatrix->red_tree_separator_level > 0);

                if (tree_active) {
                    // Tree-reduction path (red_tree_separator_level > 0).
                    if (tile_type_mode == 0) {
                        omp_dpotrf_reduction_dense(tiledMatrix, dep_tracker, worldsize);
                    } else if (tile_type_mode == 1) {
                        if (has_semisparse) {
                            omp_dpotrf_reduction_semi(tiledMatrix, dep_tracker, worldsize);
                        } else {
                            omp_dpotrf_reduction_dense(tiledMatrix, dep_tracker, worldsize);
                        }
                    } else {
                        #pragma omp single
                        {
                            sTiles::Logger::error("omp_pdpotrf: tile_type_mode=", tile_type_mode,
                                                  " + tree-reduction path unsupported.");
                            dep_tracker->abort_flag.store(true, std::memory_order_release);
                        }
                    }

                } else if (tile_type_mode == 0) {
                    // Dense mode
                    if (serial_path) {
                        // Single-threaded worker — only one OMP thread runs the
                        // full task list; the rest wait at the implicit barrier.
                        #pragma omp single
                        sTiles::Process::omp_dpotrf_expansion_dense_serial(tiledMatrix, dep_tracker);
                    } else {
                        omp_dpotrf_expansion_dense_parallel(tiledMatrix, dep_tracker, worldsize);
                    }

                } else if (tile_type_mode == 1) {
                    // Semisparse mode
                    if (has_semisparse) {
                        if (serial_path) {
                            // Single-threaded semisparse worker — wrap in omp single so
                            // only one thread runs the full task list (matches dense path).
                            #pragma omp single
                            sTiles::Process::omp_dpotrf_expansion_semi_serial_imp4(tiledMatrix, dep_tracker);
                        } else {
                            omp_dpotrf_expansion_semi_parallel_imp4(tiledMatrix, dep_tracker, worldsize);
                        }
                    } else {
                        // Fallback to dense mode (e.g., for single-tile matrices)
                        omp_dpotrf_expansion_dense_parallel(tiledMatrix, dep_tracker, worldsize);
                    }

                } else {
                    // tile_type_mode == 2 (nonunif) is expected to be handled
                    // upstream by sTiles::sparse (see dpotrf.cpp short-circuit on
                    // scheme->sparse_handle). Reaching here means preprocessing
                    // didn't build a sparse_handle — flag it.
                    #pragma omp single
                    {
                        sTiles::Logger::error("omp_pdpotrf: tile_type_mode=",
                                                tile_type_mode,
                                                " has no in-pdpotrf path; expected sparse_handle to short-circuit.");
                        dep_tracker->abort_flag.store(true, std::memory_order_release);
                    }
                }
            } else {
                // Dense variants 1 and 2 without pre-collected tasks.
                // Variant 1: single tile (numActiveTiles == 1, dimTiledMatrix == 1)
                // Variant 2: scaled dense (numActiveTiles == triangular_size)
                const int num_active = tiledMatrix->numActiveTiles;
                const int dim_tiled  = tiledMatrix->dimTiledMatrix;
                const int tri_size   = tiledMatrix->triangular_size;

                if (num_active == 1 && dim_tiled == 1) {
                    sTiles::Process::omp_dpotrf_full_dense(tiledMatrix, dep_tracker, 1, worldsize);
                } else if (num_active == tri_size && tri_size > 0) {
                    sTiles::Process::omp_dpotrf_full_dense(tiledMatrix, dep_tracker, 2, worldsize);
                }
            }

            // Record Cholesky status: 0 = success, 1 = not positive definite
            #pragma omp single
            {
                tiledMatrix->chol_info.store(
                    dep_tracker->abort_flag.load(std::memory_order_acquire) ? 1 : 0,
                    std::memory_order_release);
            }
        }

